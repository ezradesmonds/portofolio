<div id="three-bg" class="fixed inset-0 z-0 pointer-events-none" aria-hidden="true"></div>

<script>
  import * as THREE from "three";

  let scene: THREE.Scene;
  let camera: THREE.PerspectiveCamera;
  let renderer: THREE.WebGLRenderer;
  let particles: THREE.Points;
  let shapes: THREE.Mesh[];
  let animFrame: number;
  let scrollY = 0;

  function init() {
    const container = document.getElementById("three-bg");
    if (!container) return;

    scene = new THREE.Scene();
    camera = new THREE.PerspectiveCamera(60, window.innerWidth / window.innerHeight, 0.1, 100);
    camera.position.z = 15;

    renderer = new THREE.WebGLRenderer({ alpha: true, antialias: true });
    renderer.setSize(window.innerWidth, window.innerHeight);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    container.appendChild(renderer.domElement);

    const particleGeo = new THREE.BufferGeometry();
    const particleCount = 400;
    const positions = new Float32Array(particleCount * 3);
    const colors = new Float32Array(particleCount * 3);

    const cyan = new THREE.Color("#00E5FF");
    const violet = new THREE.Color("#8B5CF6");

    for (let i = 0; i < particleCount; i++) {
      positions[i * 3] = (Math.random() - 0.5) * 30;
      positions[i * 3 + 1] = (Math.random() - 0.5) * 20;
      positions[i * 3 + 2] = (Math.random() - 0.5) * 10;

      const mixed = cyan.clone().lerp(violet, Math.random());
      colors[i * 3] = mixed.r;
      colors[i * 3 + 1] = mixed.g;
      colors[i * 3 + 2] = mixed.b;
    }

    particleGeo.setAttribute("position", new THREE.BufferAttribute(positions, 3));
    particleGeo.setAttribute("color", new THREE.BufferAttribute(colors, 3));

    const particleMat = new THREE.PointsMaterial({
      size: 0.04,
      vertexColors: true,
      blending: THREE.AdditiveBlending,
      depthWrite: false,
      transparent: true,
      opacity: 0.6,
    });

    particles = new THREE.Points(particleGeo, particleMat);
    scene.add(particles);

    shapes = [];
    const wireframeMat = new THREE.MeshBasicMaterial({
      color: 0x8B5CF6,
      wireframe: true,
      transparent: true,
      opacity: 0.06,
    });

    const geo1 = new THREE.IcosahedronGeometry(2.5, 1);
    const shape1 = new THREE.Mesh(geo1, wireframeMat);
    shape1.position.set(-6, 3, -3);
    scene.add(shape1);
    shapes.push(shape1);

    const geo2 = new THREE.TorusKnotGeometry(1.8, 0.3, 64, 8);
    const shape2 = new THREE.Mesh(geo2, wireframeMat.clone());
    shape2.position.set(5, -2, -2);
    scene.add(shape2);
    shapes.push(shape2);

    const geo3 = new THREE.OctahedronGeometry(1.6);
    const shape3 = new THREE.Mesh(geo3, wireframeMat.clone());
    shape3.position.set(3, 4, -4);
    scene.add(shape3);
    shapes.push(shape3);

    const geo4 = new THREE.TetrahedronGeometry(1.4);
    const shape4 = new THREE.Mesh(geo4, wireframeMat.clone());
    shape4.position.set(-4, -3, -2);
    scene.add(shape4);
    shapes.push(shape4);

    window.addEventListener("scroll", () => {
      scrollY = window.scrollY;
    });

    window.addEventListener("resize", () => {
      camera.aspect = window.innerWidth / window.innerHeight;
      camera.updateProjectionMatrix();
      renderer.setSize(window.innerWidth, window.innerHeight);
    });

    animate();
  }

  function animate() {
    animFrame = requestAnimationFrame(animate);

    const time = Date.now() * 0.0005;
    const parallax = scrollY * 0.0002;

    particles.rotation.y += 0.0003;
    particles.rotation.x += 0.0001;

    shapes.forEach((shape, i) => {
      shape.rotation.x += 0.002 + i * 0.0005;
      shape.rotation.y += 0.003 + i * 0.0005;
      shape.position.y += Math.sin(time + i) * 0.003;
    });

    camera.position.y = -parallax * 5;

    renderer.render(scene, camera);
  }

  function cleanup() {
    if (animFrame) cancelAnimationFrame(animFrame);
    if (renderer) {
      renderer.dispose();
      const el = renderer.domElement;
      if (el.parentNode) el.parentNode.removeChild(el);
    }
    if (particles) {
      particles.geometry.dispose();
      (particles.material as THREE.Material).dispose();
    }
    shapes?.forEach((s) => {
      s.geometry.dispose();
      (s.material as THREE.Material).dispose();
    });
  }

  document.addEventListener("DOMContentLoaded", init);
  document.addEventListener("astro:after-swap", cleanup);
</script>
