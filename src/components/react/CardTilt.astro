<script>
  function initCardTilt() {
    const cards = document.querySelectorAll("[data-project-slug]");
    if (!cards.length) return;

    cards.forEach((card) => {
      const el = card as HTMLElement;
      el.style.transformStyle = "preserve-3d";
      el.style.perspective = "1000px";

      el.addEventListener("mousemove", (e: Event) => {
        const me = e as MouseEvent;
        const rect = el.getBoundingClientRect();
        const x = me.clientX - rect.left;
        const y = me.clientY - rect.top;
        const centerX = rect.width / 2;
        const centerY = rect.height / 2;
        const rotateX = ((y - centerY) / centerY) * -4;
        const rotateY = ((x - centerX) / centerX) * 4;

        el.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) translateY(-4px)`;
        el.style.boxShadow = `0 20px 40px -15px rgba(139, 92, 246, ${Math.abs(rotateX + rotateY) * 0.005})`;
      });

      el.addEventListener("mouseleave", () => {
        el.style.transform = "perspective(1000px) rotateX(0) rotateY(0) translateY(0)";
        el.style.boxShadow = "";
        el.style.transition = "transform 0.5s ease, box-shadow 0.5s ease";
      });

      el.addEventListener("mouseenter", () => {
        el.style.transition = "transform 0.1s ease";
      });
    });
  }

  document.addEventListener("DOMContentLoaded", initCardTilt);
</script>
