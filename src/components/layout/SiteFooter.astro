---
import { SITE } from "../../data/site";
---

<footer class="border-t border-dark-border bg-dark-base">
  <div class="max-w-7xl mx-auto px-4 md:px-6 py-12 md:py-16">
    <div class="grid md:grid-cols-2 gap-8 md:gap-12 items-start">
      <div>
        <a href="/" class="text-2xl font-bold text-white">Ezra<span class="text-accent-cyan">.</span></a>
        <p class="text-text-secondary text-sm max-w-sm mt-4 leading-relaxed">
          Software engineer and AI product builder creating full-stack systems that solve real-world problems.
        </p>
      </div>

      <div class="grid grid-cols-2 gap-8">
        <div>
          <h3 class="text-xs font-mono font-bold uppercase tracking-widest text-accent-cyan mb-4">Navigation</h3>
          <ul class="space-y-2">
            <li><a href="/#work" class="text-sm text-text-secondary hover:text-white transition-colors">Work</a></li>
            <li><a href="/#experience" class="text-sm text-text-secondary hover:text-white transition-colors">Experience</a></li>
            <li><a href="/#about" class="text-sm text-text-secondary hover:text-white transition-colors">About</a></li>
            <li><a href="/#contact" class="text-sm text-text-secondary hover:text-white transition-colors">Contact</a></li>
          </ul>
        </div>
        <div>
          <h3 class="text-xs font-mono font-bold uppercase tracking-widest text-accent-cyan mb-4">Links</h3>
          <ul class="space-y-2">
            <li><a href={SITE.github} target="_blank" rel="noopener noreferrer" class="text-sm text-text-secondary hover:text-white transition-colors">GitHub</a></li>
            <li><a href={SITE.linkedin} target="_blank" rel="noopener noreferrer" class="text-sm text-text-secondary hover:text-white transition-colors">LinkedIn</a></li>
            <li><a href={SITE.instagram} target="_blank" rel="noopener noreferrer" class="text-sm text-text-secondary hover:text-white transition-colors">Instagram</a></li>
            <li><a href={`mailto:${SITE.email}`} class="text-sm text-text-secondary hover:text-white transition-colors">Email</a></li>
          </ul>
        </div>
      </div>
    </div>

    <div class="border-t border-dark-border mt-10 md:mt-12 pt-6 md:pt-8 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-xs text-text-muted font-mono">
        &copy; {new Date().getFullYear()} {SITE.name}
      </p>
      <p class="text-[11px] md:text-xs text-text-muted font-mono">
        Built with Astro &middot; TypeScript &middot; Three.js
      </p>
    </div>
  </div>
</footer>
