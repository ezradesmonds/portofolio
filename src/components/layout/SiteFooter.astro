---
import { localizedPath, resolveLang, t } from "../../i18n/utils";
import type { TranslationKey } from "../../i18n/translations";
import { SITE } from "../../data/site";

const lang = resolveLang(Astro.url.searchParams.get("lang"), Astro.url.pathname);
const homeHref = localizedPath(lang, "/");

const navItems: { href: string; key: TranslationKey }[] = [
  { href: `${homeHref}#work`, key: "nav.work" },
  { href: `${homeHref}#experience`, key: "nav.experience" },
  { href: `${homeHref}#about`, key: "nav.about" },
  { href: `${homeHref}#contact`, key: "nav.contact" },
];
---

<footer class="border-t border-dark-border bg-dark-base">
  <div class="max-w-7xl mx-auto px-4 md:px-6 py-12 md:py-16">
    <div class="grid md:grid-cols-2 gap-8 md:gap-12 items-start">
      <div>
        <a href={homeHref} class="footer-brand text-2xl font-black text-white">
          <img src="/ezra-mark.png" alt="" width="34" height="34" loading="lazy" decoding="async" />
          Ezra<span class="text-accent-cyan">.</span>
        </a>
        <p class="text-text-secondary text-sm max-w-sm mt-4 leading-relaxed">
          {t(lang, "footer.tagline")}
        </p>
      </div>

      <div class="grid grid-cols-2 gap-8">
        <div>
          <h3 class="text-xs font-mono font-bold uppercase tracking-widest text-accent-cyan mb-4">{t(lang, "footer.navigation")}</h3>
          <ul class="space-y-2">
            {navItems.map((item) => (
              <li><a href={item.href} class="text-sm text-text-secondary hover:text-white transition-colors">{t(lang, item.key)}</a></li>
            ))}
          </ul>
        </div>
        <div>
          <h3 class="text-xs font-mono font-bold uppercase tracking-widest text-accent-cyan mb-4">{t(lang, "footer.links")}</h3>
          <ul class="space-y-2">
            <li><a href={SITE.github} target="_blank" rel="noopener noreferrer" class="text-sm text-text-secondary hover:text-white transition-colors">GitHub</a></li>
            <li><a href={SITE.linkedin} target="_blank" rel="noopener noreferrer" class="text-sm text-text-secondary hover:text-white transition-colors">LinkedIn</a></li>
            <li><a href={SITE.instagram} target="_blank" rel="noopener noreferrer" class="text-sm text-text-secondary hover:text-white transition-colors">Instagram</a></li>
            <li><a href={SITE.cvUrl} download class="text-sm text-text-secondary hover:text-white transition-colors">{t(lang, "nav.downloadCv")}</a></li>
            <li><a href={`mailto:${SITE.email}`} class="text-sm text-text-secondary hover:text-white transition-colors">{t(lang, "footer.email")}</a></li>
          </ul>
        </div>
      </div>
    </div>

    <div class="border-t border-dark-border mt-10 md:mt-12 pt-6 md:pt-8 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-xs text-text-muted font-mono">
        &copy; {new Date().getFullYear()} {SITE.name}
      </p>
      <p class="text-[11px] md:text-xs text-text-muted font-mono">
        {t(lang, "footer.builtWith")}
      </p>
    </div>
  </div>
</footer>

<style>
  .footer-brand {
    display: inline-flex;
    align-items: center;
    gap: 0.58rem;
    font-family: var(--font-display);
    letter-spacing: -0.02em;
    transition: color 0.2s ease;
  }

  .footer-brand:hover {
    color: var(--color-accent-cyan);
  }

  .footer-brand img {
    width: 1.95rem;
    height: 1.95rem;
    border-radius: 0.58rem;
    object-fit: cover;
    box-shadow: 0 0 22px rgba(244, 255, 114, 0.14);
  }
</style>
