---
import { alternateLangPath, localizedPath, t } from "../../i18n/utils";
import type { Lang, TranslationKey } from "../../i18n/translations";
import { SITE } from "../../data/site";
import MobileMenu from "../interactive/MobileMenu.astro";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const homeHref = localizedPath(lang, "/");
const currentLangLabel = lang.toUpperCase();
const switcherHref = alternateLangPath(lang, Astro.url.pathname);
const switcherTitle = lang === "en" ? "Switch to Bahasa Indonesia" : "Switch to English";

const navItems: { href: string; key: TranslationKey }[] = [
  { href: `${homeHref}#work`, key: "nav.work" },
  { href: localizedPath(lang, "/play/"), key: "nav.play" },
  { href: `${homeHref}#experience`, key: "nav.experience" },
  { href: `${homeHref}#about`, key: "nav.about" },
  { href: `${homeHref}#contact`, key: "nav.contact" },
];
---

<header class="fixed top-0 left-0 right-0 z-50 transition-all duration-300" id="site-header">
  <nav
    class="mx-auto max-w-7xl px-4 sm:px-6 py-3 sm:py-4 flex justify-between items-center"
    aria-label="Main navigation"
  >
    <div class="flex min-w-0 items-center gap-2 sm:gap-3">
      <a
        href={`${homeHref}#hero`}
        class="brand-logo shrink-0 text-lg sm:text-xl font-black text-white hover:text-accent-cyan transition-colors"
        aria-label="Go to homepage"
      >
        <img src="/ezra-mark.png" alt="" width="28" height="28" class="brand-mark" loading="eager" decoding="async" />
        <span class="brand-name">Ezra<span class="text-accent-cyan">.</span></span>
      </a>
      <a
        href={switcherHref}
        class="language-toggle"
        title={switcherTitle}
        aria-label={switcherTitle}
      >
        {currentLangLabel}
      </a>
    </div>

    <div class="hidden md:flex items-center space-x-1">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class="px-3 py-2 text-sm font-medium text-text-secondary hover:text-white transition-colors relative group rounded-md"
          >
            {t(lang, item.key)}
            <span class="absolute bottom-1 left-3 right-3 h-px bg-accent-cyan scale-x-0 group-hover:scale-x-100 transition-transform origin-left"></span>
          </a>
        ))
      }
      <a
        href={SITE.cvUrl}
        download
        class="px-3 py-2 text-sm font-medium text-text-secondary hover:text-white transition-colors relative group rounded-md"
      >
        {t(lang, "nav.downloadCv")}
        <span class="absolute bottom-1 left-3 right-3 h-px bg-accent-cyan scale-x-0 group-hover:scale-x-100 transition-transform origin-left"></span>
      </a>
      <a
        href={`mailto:${SITE.email}`}
        class="ml-3 px-4 py-1.5 text-sm font-semibold border border-accent-cyan/30 text-accent-cyan rounded-lg hover:bg-accent-cyan/10 transition-colors"
      >
        {t(lang, "nav.getInTouch")}
      </a>
    </div>

    <MobileMenu lang={lang} />
  </nav>

  <div
    class="absolute inset-0 -z-10 glass-nav border-b border-white/5"
    aria-hidden="true"
  ></div>
</header>

<style>
  .glass-nav {
    background: rgba(7, 8, 5, 0.78);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
  }

  #site-header {
    transform: translateY(0);
    transition: transform 0.3s ease, background-color 0.3s ease;
  }

  .brand-logo {
    display: inline-flex;
    align-items: center;
    flex-wrap: nowrap;
    gap: 0.42rem;
    font-family: var(--font-display);
    letter-spacing: -0.02em;
    line-height: 1;
    white-space: nowrap;
  }

  .brand-name {
    display: inline-flex;
    align-items: baseline;
    line-height: 1;
  }

  .brand-mark {
    display: block;
    flex: 0 0 auto;
    width: 1.45rem;
    height: 1.45rem;
    border-radius: 0.42rem;
    object-fit: cover;
    box-shadow: 0 0 18px rgba(244, 255, 114, 0.14);
  }

  @media (min-width: 640px) {
    .brand-mark {
      width: 1.6rem;
      height: 1.6rem;
      border-radius: 0.48rem;
    }
  }

  .language-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.1rem;
    height: 1.45rem;
    border: 1px solid rgba(244, 255, 114, 0.34);
    border-radius: 999px;
    color: var(--color-accent-cyan);
    background: rgba(244, 255, 114, 0.08);
    font-family: var(--font-mono);
    font-size: 0.62rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    transition: transform 0.2s ease, border-color 0.2s ease, background-color 0.2s ease;
  }

  .language-toggle:hover {
    transform: translateY(-1px);
    border-color: rgba(244, 255, 114, 0.75);
    background: rgba(244, 255, 114, 0.14);
  }
</style>
