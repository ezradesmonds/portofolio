---
interface Props {
  number: string;
  title: string;
  subtitle?: string;
}

const { number, title, subtitle } = Astro.props;
---

<div class="section-heading mb-10 sm:mb-16" data-reveal data-reveal-delay="0">
  <span class="section-num">file / {number}</span>
  <h2 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-black text-white mt-2 sm:mt-3">{title}</h2>
  {subtitle && (
    <p class="text-sm sm:text-base md:text-lg text-text-secondary mt-3 sm:mt-4 max-w-2xl">{subtitle}</p>
  )}
</div>

<style>
  .section-heading h2 {
    font-family: var(--font-display);
    letter-spacing: -0.035em;
    line-height: 0.98;
    text-wrap: balance;
  }
</style>
