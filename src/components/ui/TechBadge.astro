---
interface Props {
  name: string;
  size?: "sm" | "md";
}

const { name, size = "sm" } = Astro.props;
const sizeClass = size === "md" ? "text-xs px-2.5 py-1" : "text-[11px] px-2 py-0.5";
---

<span class={`${sizeClass} font-mono text-text-muted bg-white/5 border border-white/10 rounded`}>
  {name}
</span>
