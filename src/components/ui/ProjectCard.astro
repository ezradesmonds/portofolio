---
import type { Project } from "../../types";

interface Props {
  project: Project;
}

const { project } = Astro.props;

const statusColorMap: Record<string, string> = {
  live: "border-green-500/40 text-green-400 bg-green-500/10",
  "in-development": "border-amber-500/40 text-amber-400 bg-amber-500/10",
  prototype: "border-sky-500/40 text-sky-400 bg-sky-500/10",
  academic: "border-slate-500/40 text-slate-400 bg-slate-500/10",
  competition: "border-violet-500/40 text-violet-400 bg-violet-500/10",
  "case-study": "border-teal-500/40 text-teal-400 bg-teal-500/10",
};

const statusColor = statusColorMap[project.status] ?? statusColorMap.prototype;
---

<div
  class="block group glass-card rounded-xl p-6 border-glow transition-all duration-300 hover:border-accent-cyan/30 hover:-translate-y-1 cursor-pointer"
  data-project-slug={project.slug}
  role="button"
  tabindex="0"
>
  <div class="flex items-start justify-between mb-4">
    <span class="text-xs font-mono text-accent-cyan">{project.category}</span>
    <span
      class={`text-[10px] font-mono font-semibold uppercase px-2 py-0.5 rounded border ${statusColor}`}
    >
      {project.statusLabel}
    </span>
  </div>

  <h3 class="text-xl font-bold text-white mb-3 group-hover:text-accent-cyan transition-colors">
    {project.title}
  </h3>

  <p class="text-sm text-text-secondary leading-relaxed mb-6 line-clamp-3">
    {project.description}
  </p>

  <div class="flex flex-wrap gap-2 mb-5">
    {project.technologies.slice(0, 5).map((tech) => (
      <span class="text-[11px] font-mono text-text-muted bg-white/5 border border-white/10 px-2 py-0.5 rounded">
        {tech}
      </span>
    ))}
    {project.technologies.length > 5 && (
      <span class="text-[11px] font-mono text-text-muted">+{project.technologies.length - 5}</span>
    )}
  </div>

  <div class="flex items-center gap-4 text-sm">
    <span class="text-accent-cyan font-semibold group-hover:underline">
      View Case Study &rarr;
    </span>
    {project.liveUrl && (
      <span class="text-text-muted text-xs ml-auto">
        Live &nearr;
      </span>
    )}
  </div>
</div>
