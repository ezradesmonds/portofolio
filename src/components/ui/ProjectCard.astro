---
import type { Project } from "../../types";
import type { Lang } from "../../i18n/translations";
import { localizedPath } from "../../i18n/utils";

interface Props {
  project: Project;
  lang: Lang;
}

const { project, lang } = Astro.props;
const projectHref = localizedPath(lang, `/work/${project.slug}/`);
const viewLabel = lang === "id" ? "Buka Studi Kasus" : "View Case Study";
const liveLabel = lang === "id" ? "Situs live" : "Live";
const proofLabel = project.proofStatus === "available"
  ? (lang === "id" ? "Bukti visual" : "Proof added")
  : project.proofStatus === "pending"
    ? (lang === "id" ? "Bukti batch 2" : "Proof pending")
    : null;

const statusColorMap: Record<string, string> = {
  live: "border-green-500/40 text-green-400 bg-green-500/10",
  "in-development": "border-amber-500/40 text-amber-400 bg-amber-500/10",
  prototype: "border-sky-500/40 text-sky-400 bg-sky-500/10",
  academic: "border-slate-500/40 text-slate-400 bg-slate-500/10",
  competition: "border-violet-500/40 text-violet-400 bg-violet-500/10",
  "case-study": "border-teal-500/40 text-teal-400 bg-teal-500/10",
};

const statusColor = statusColorMap[project.status] ?? statusColorMap.prototype;
---

<a
  href={projectHref}
  class="case-card block group glass-card rounded-xl p-4 sm:p-6 transition-all duration-300 hover:-translate-y-1"
  data-project-slug={project.slug}
>
  {project.screenshot && (
    <div class="case-shot mb-4" aria-hidden="true">
      <img src={project.screenshot} alt="" loading="lazy" decoding="async" />
    </div>
  )}

  <div class="flex items-start justify-between gap-3 mb-4">
    <span class="case-label line-clamp-1">{project.category}</span>
    <span
      class={`text-[9px] sm:text-[10px] font-mono font-semibold uppercase px-1.5 sm:px-2 py-0.5 rounded border ${statusColor} flex-shrink-0`}
    >
      {project.statusLabel}
    </span>
  </div>

  {(proofLabel || project.liveUrl) && (
    <div class="evidence-row">
      {project.liveUrl && (
        <span class="live-chip">
          <span class="live-dot" aria-hidden="true"></span>
          {liveLabel}
        </span>
      )}
      {proofLabel && (
        <span class={`proof-chip ${project.proofStatus === "pending" ? "is-pending" : ""}`}>
          {proofLabel}
        </span>
      )}
    </div>
  )}

  <h3 class="case-title text-xl sm:text-2xl font-black text-white mb-2 sm:mb-3 group-hover:text-accent-cyan transition-colors">
    {project.title}
  </h3>

  <p class="text-xs sm:text-sm text-text-secondary leading-relaxed mb-5 sm:mb-6 line-clamp-3">
    {project.description}
  </p>

  <div class="flex flex-wrap gap-1.5 sm:gap-2 mb-4 sm:mb-5">
    {project.technologies.slice(0, 4).map((tech) => (
      <span class="text-[10px] sm:text-[11px] font-mono text-text-muted bg-white/5 border border-white/10 px-1.5 sm:px-2 py-0.5 rounded-full">
        {tech}
      </span>
    ))}
    {project.technologies.length > 5 && (
      <span class="text-[11px] font-mono text-text-muted">+{project.technologies.length - 5}</span>
    )}
  </div>

  <div class="flex items-center gap-4 text-sm">
    <span class="text-accent-cyan font-bold group-hover:underline">
      {viewLabel} &rarr;
    </span>
    {project.liveUrl && (
      <span class="text-text-muted text-xs ml-auto">
        {liveLabel} &nearr;
      </span>
    )}
  </div>
</a>

<style>
  .case-card {
    position: relative;
    overflow: hidden;
    min-height: 18rem;
    text-decoration: none;
  }

  .case-shot {
    position: relative;
    overflow: hidden;
    aspect-ratio: 16 / 9;
    border: 1px solid rgba(244, 255, 114, 0.14);
    border-radius: 0.65rem;
    background: rgba(0, 0, 0, 0.3);
  }

  .case-shot img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(0.92) contrast(1.05);
    transform: scale(1.01);
    transition: transform 0.35s ease, filter 0.35s ease;
  }

  .case-card:hover .case-shot img {
    filter: saturate(1.05) contrast(1.08);
    transform: scale(1.045);
  }

  .evidence-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.45rem;
    margin-bottom: 0.85rem;
  }

  .proof-chip,
  .live-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    width: fit-content;
    border: 1px solid rgba(244, 255, 114, 0.22);
    border-radius: 999px;
    background: rgba(244, 255, 114, 0.07);
    color: var(--color-accent-cyan);
    font-family: var(--font-mono);
    font-size: 0.62rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    padding: 0.22rem 0.5rem;
    text-transform: uppercase;
  }

  .live-chip {
    border-color: rgba(56, 255, 163, 0.28);
    background: rgba(56, 255, 163, 0.08);
    color: rgb(104, 255, 185);
  }

  .live-dot {
    width: 0.38rem;
    height: 0.38rem;
    border-radius: 999px;
    background: currentColor;
    box-shadow: 0 0 0.7rem currentColor;
  }

  .proof-chip.is-pending {
    border-color: rgba(255, 255, 255, 0.12);
    background: rgba(255, 255, 255, 0.045);
    color: var(--color-text-muted);
  }

  .case-card::before {
    content: "";
    position: absolute;
    inset: 0;
    border-top: 4px solid var(--color-accent-cyan);
    opacity: 0.9;
    pointer-events: none;
  }

  .case-card::after {
    content: "CASE";
    position: absolute;
    right: 0.75rem;
    bottom: 0.45rem;
    color: rgba(244, 255, 114, 0.07);
    font-family: var(--font-display);
    font-size: 4.5rem;
    font-weight: 900;
    line-height: 1;
    letter-spacing: -0.06em;
    pointer-events: none;
  }

  .case-label {
    color: var(--color-accent-cyan);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .case-title {
    font-family: var(--font-display);
    letter-spacing: -0.025em;
  }
</style>
