---
import { resolveLang, t } from "../../i18n/utils";
import SectionHeading from "../ui/SectionHeading.astro";

const lang = resolveLang(Astro.url.searchParams.get("lang"), Astro.url.pathname);
const principles = lang === "id"
  ? ["Jelas dulu, baru cepat", "Sistem sebelum mood", "Eksekusi sebelum wacana"]
  : ["Clarity before speed", "Systems before vibes", "Execution before talk"];
const identityLabel = lang === "id" ? "Catatan operasi" : "Operating notes";
const aboutColumns = lang === "id"
  ? [
      [
        [
          { text: "Ezra Desmond Sutanto adalah " },
          { text: "mahasiswa Informatika di Universitas Kristen Petra Surabaya", strong: true },
          { text: ", saat ini semester empat dengan " },
          { text: "IPK 3.76 / 4.00", strong: true },
          { text: ". Ia adalah " },
          { text: "AI dan full-stack builder", strong: true },
          { text: " yang fokus menciptakan sistem untuk membantu orang ambisius bekerja dengan lebih jelas dan mengeksekusi ide lebih cepat. Karyanya mencakup full-stack web development, kecerdasan buatan, sistem produktivitas, business tools, eksperimen teknologi finansial, dan desain produk." },
        ],
        [
          { text: "Ia ingin membangun sistem yang membantu orang ambisius " },
          { text: "bergerak lebih cepat, berpikir lebih jernih, dan mencapai lebih banyak hal", strong: true },
          { text: ". Saat ini, ia memulai dari " },
          { text: "mahasiswa ambisius, builder muda, dan entrepreneur tahap awal", strong: true },
          { text: ": orang-orang dengan ambisi kuat yang sering terhambat oleh alat yang terpencar, information overload, dan kesulitan mengubah ide menjadi aksi yang konsisten." },
        ],
      ],
      [
        [
          { text: "Melalui produk bertenaga AI, Ezra ingin membantu orang " },
          { text: "mengurangi kekacauan, mengambil keputusan lebih baik, dan bergerak dari niat menuju eksekusi", strong: true },
          { text: ". Proyek-proyek sebelumnya di akuntansi, commerce, credit intelligence, edukasi kesehatan, operasional event, riset finansial, marketplace jasa, manajemen koperasi, dan workflow berbasis AI kini menjadi bagian dari arah yang lebih luas: membangun execution systems." },
        ],
        [
          { text: "Di luar engineering, Ezra tertarik pada musik dan gitar, product building, pasar finansial, dan kewirausahaan teknologi. Ia terbuka untuk " },
          { text: "magang, kolaborasi, dan peluang membangun sistem bertenaga AI", strong: true },
          { text: " yang menghemat waktu, meningkatkan kejelasan, mempercepat eksekusi, dan membantu lebih banyak ide menjadi kenyataan." },
        ],
      ],
    ]
  : [
      [
        [
          { text: "Ezra Desmond Sutanto is an " },
          { text: "Informatics student at Petra Christian University", strong: true },
          { text: ", Surabaya, currently in the fourth semester with a " },
          { text: "GPA of 3.76 / 4.00", strong: true },
          { text: ". He is an " },
          { text: "AI and full-stack builder", strong: true },
          { text: " focused on creating systems that help ambitious people work with more clarity and execute their ideas faster. His work spans full-stack web development, artificial intelligence, productivity systems, business tools, financial technology experiments, and product design." },
        ],
        [
          { text: "He wants to build systems that help ambitious people " },
          { text: "move faster, think clearer, and achieve more", strong: true },
          { text: ". Today, he is starting with " },
          { text: "students, young builders, and early-stage entrepreneurs", strong: true },
          { text: ": people with strong ambitions who are often limited by scattered tools, information overload, and difficulty turning ideas into consistent action." },
        ],
      ],
      [
        [
          { text: "Through AI-powered products, Ezra wants to help people " },
          { text: "reduce chaos, make better decisions, and move from intention to execution", strong: true },
          { text: ". His past projects across accounting, commerce, credit intelligence, health education, event operations, financial research, service marketplaces, cooperative management, and AI-assisted workflows are now part of that broader execution-systems direction." },
        ],
        [
          { text: "Outside engineering, Ezra is interested in music and guitar, product building, financial markets, and technology entrepreneurship. He is open to " },
          { text: "internships, collaborations, and opportunities to build AI-powered systems", strong: true },
          { text: " that save time, improve clarity, accelerate execution, and help more ideas become reality." },
        ],
      ],
    ];
---

<section id="about" class="section bg-dark-surface/30">
  <div class="container-lg">
    <SectionHeading
      number="01."
      title={t(lang, "about.title")}
    />

    <div class="about-grid grid lg:grid-cols-[0.75fr_1.25fr] gap-6 md:gap-10 max-w-6xl">
      <aside class="identity-note" data-scramble-note>
        <p class="identity-label">{identityLabel}</p>
        <ul>
          {principles.map((principle) => <li data-scramble-text={principle}>{principle}</li>)}
        </ul>
      </aside>

      <div class="about-copy grid md:grid-cols-2 gap-6 md:gap-10 text-text-secondary leading-relaxed text-sm md:text-base">
        {aboutColumns.map((column) => (
          <div class="space-y-5">
            {column.map((paragraph) => (
              <p>
                {paragraph.map((segment) => segment.strong ? <strong>{segment.text}</strong> : segment.text)}
              </p>
            ))}
          </div>
        ))}
      </div>
    </div>

    <div class="mt-12 max-w-5xl">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded bg-accent-cyan/5 border border-accent-cyan/20 text-xs font-mono text-accent-cyan">
        {t(lang, "about.education.label")}
      </div>
      <p class="text-text-secondary mt-3">
        <span class="text-white font-semibold">{t(lang, "about.education.school")}</span>
        <span class="mx-2 text-text-muted">&mdash;</span>
        {t(lang, "about.education.detail")}
      </p>
    </div>
  </div>
</section>

<script>
  function initIdentityScramble() {
    const notes = document.querySelectorAll("[data-scramble-note]");
    if (!notes.length) return;

    const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789/<>-_";
    const timers = new WeakMap();

    function scramble(el) {
      if (prefersReduced) return;

      const target = el.getAttribute("data-scramble-text") || el.textContent || "";
      let frame = 0;
      const total = Math.max(18, target.length * 2);
      const existingTimer = timers.get(el);

      if (existingTimer) window.clearInterval(existingTimer);
      const timer = window.setInterval(() => {
        const progress = frame / total;
        el.textContent = target
          .split("")
          .map((char, index) => {
            if (char === " ") return " ";
            if (index / target.length < progress) return char;
            return chars[Math.floor(Math.random() * chars.length)];
          })
          .join("");

        frame += 1;
        if (frame > total) {
          window.clearInterval(timer);
          el.textContent = target;
        }
      }, 28);
      timers.set(el, timer);
    }

    notes.forEach((note) => {
      const rows = Array.from(note.querySelectorAll("[data-scramble-text]"));

      rows.forEach((row) => {
        row.addEventListener("mouseenter", () => scramble(row));
        row.addEventListener("focus", () => scramble(row));
      });

      note.addEventListener("pointermove", (event) => {
        const rect = note.getBoundingClientRect();
        note.style.setProperty("--note-x", `${event.clientX - rect.left}px`);
        note.style.setProperty("--note-y", `${event.clientY - rect.top}px`);
      });

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            rows.forEach((row, index) => {
              window.setTimeout(() => scramble(row), index * 180);
            });
            observer.disconnect();
          });
        },
        { threshold: 0.55 }
      );

      observer.observe(note);
    });
  }

  document.addEventListener("DOMContentLoaded", initIdentityScramble);
</script>

<style>
  .identity-note {
    --note-x: 50%;
    --note-y: 50%;
    position: relative;
    overflow: hidden;
    align-self: start;
    border: 1px solid rgba(244, 255, 114, 0.18);
    border-radius: 16px;
    background: #e8e2cf;
    color: #10120b;
    padding: 1.1rem;
    transform: rotate(-1.5deg);
    box-shadow: 0 16px 0 rgba(0, 0, 0, 0.22);
  }

  .identity-note::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(circle at var(--note-x) var(--note-y), rgba(244, 255, 114, 0.28), transparent 8rem);
    opacity: 0;
    mix-blend-mode: multiply;
    transition: opacity 0.2s ease;
  }

  .identity-note:hover::before {
    opacity: 0.55;
  }

  .identity-label {
    position: relative;
    color: #697200;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .identity-note ul {
    position: relative;
    display: grid;
    gap: 0.75rem;
    margin-top: 1.1rem;
  }

  .identity-note li {
    border-top: 1px solid rgba(16, 18, 11, 0.18);
    padding-top: 0.75rem;
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 3vw, 2rem);
    font-weight: 900;
    line-height: 0.95;
    letter-spacing: -0.04em;
    transition: color 0.2s ease, transform 0.2s ease;
  }

  .identity-note li:hover,
  .identity-note li:focus-visible {
    color: #ff6b35;
    transform: translateX(0.2rem);
  }

  .about-copy strong {
    color: var(--color-text-primary);
    font-weight: 850;
  }
</style>
