---
import ProfileCard from "../interactive/ProfileCard";
import { localizedPath, resolveLang, t } from "../../i18n/utils";
import { SITE } from "../../data/site";

const lang = resolveLang(Astro.url.searchParams.get("lang"), Astro.url.pathname);
const homeHref = localizedPath(lang, "/");
const signals = lang === "id"
  ? ["Sistem AI", "Alat eksekusi", "Loop kerja"]
  : ["AI systems", "Builder tools", "Execution loops"];
---

<section id="hero" class="hero-section min-h-[90vh] md:min-h-screen flex items-center pt-24 pb-14 md:py-20 relative px-4 md:px-6">
  <div class="max-w-7xl mx-auto w-full grid md:grid-cols-[0.92fr_1.08fr] lg:grid-cols-[0.95fr_1.05fr] gap-10 md:gap-8 xl:gap-16 items-center">
    <div class="z-10 max-w-full overflow-hidden">
      <div
        class="hero-pill relative pl-6 pr-3 py-1.5 text-xs font-bold text-accent-cyan mb-6 sm:mb-8 leading-relaxed"
        data-reveal data-reveal-delay="100"
      >
        <span class="absolute left-2.5 top-1/2 -translate-y-1/2 flex h-1.5 w-1.5 flex-shrink-0">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent-cyan opacity-75"></span>
          <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-accent-cyan"></span>
        </span>
        {t(lang, "hero.availability")}
      </div>

      <h1 class="hero-title text-4xl sm:text-5xl md:text-6xl xl:text-7xl font-black text-white leading-[0.92] tracking-tight max-w-3xl" data-reveal data-reveal-delay="200">
        <span>{t(lang, "hero.headline")}</span>
      </h1>

      <p class="hero-role mt-4 text-lg sm:text-xl md:text-2xl font-black text-accent-cyan" data-reveal data-reveal-delay="300">
        {t(lang, "hero.role")}
      </p>

      <p class="text-base md:text-lg xl:text-xl text-text-secondary max-w-xl mt-5 sm:mt-6 md:mt-8 leading-relaxed" data-reveal data-reveal-delay="400">
        {t(lang, "hero.subheadline")}
      </p>

      <div class="hero-signals flex flex-wrap gap-2.5 mt-6" data-reveal data-reveal-delay="500">
        {signals.map((signal) => <span>{signal}</span>)}
      </div>

      <div class="flex flex-wrap gap-3 md:gap-4 mt-8 md:mt-10" data-reveal data-reveal-delay="600">
        <a href={`${homeHref}#work`} class="btn btn-primary">
          {t(lang, "hero.ctaPrimary")}
        </a>
        <a href={SITE.cvUrl} class="btn btn-cv" download>
          {t(lang, "hero.ctaCv")}
        </a>
        <a href={`mailto:${SITE.email}`} class="hero-contact-link">
          {t(lang, "hero.ctaSecondary")} &rarr;
        </a>
      </div>

      <div class="hero-socials flex flex-wrap items-center gap-2.5 mt-5 sm:mt-6" data-reveal data-reveal-delay="800">
        <a
          href={SITE.github}
          target="_blank"
          rel="noopener noreferrer"
          class="hero-social-link"
          aria-label="GitHub profile"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" /></svg>
          {t(lang, "hero.github")}
        </a>
        <a
          href={SITE.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="hero-social-link"
          aria-label="LinkedIn profile"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          {t(lang, "hero.linkedin")}
        </a>
        <a
          href={SITE.instagram}
          target="_blank"
          rel="noopener noreferrer"
          class="hero-social-link"
          aria-label="Instagram profile"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          {t(lang, "hero.instagram")}
        </a>
      </div>
    </div>

    <div class="credential-column flex justify-center z-10" data-reveal data-reveal-delay="700">
      <ProfileCard
        client:load
        name="Ezra Desmond Sutanto"
        title={t(lang, "hero.role")}
        handle="ezradesmonds"
        status={t(lang, "hero.availability")}
        avatarUrl="/images/profile/ezra-portrait.webp"
        alternateAvatarUrl="/images/profile/ezra-portrait-pixel.png"
        avatarAlt={t(lang, "hero.credential.portraitAlt")}
        iconUrl="/ezra-mark.png"
        enableTilt={true}
        enableMobileTilt={false}
        behindGlowEnabled={true}
        behindGlowColor="rgba(244, 255, 114, 0.38)"
        innerGradient="linear-gradient(145deg, rgba(39, 45, 21, 0.94), rgba(7, 8, 5, 0.98))"
        alternateAvatarText={t(lang, "hero.credential.pixel")}
        primaryAvatarText={t(lang, "hero.credential.real")}
        alternateAvatarLabel={t(lang, "hero.credential.showPixel")}
        primaryAvatarLabel={t(lang, "hero.credential.showReal")}
      />
    </div>
  </div>
</section>

<style>
  .hero-section::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(circle at 13% 24%, rgba(244, 255, 114, 0.12), transparent 22rem),
      radial-gradient(circle at 84% 34%, rgba(63, 142, 255, 0.11), transparent 26rem);
    opacity: 0.9;
  }

  .hero-section::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 0;
    display: none;
    pointer-events: none;
    background-image:
      radial-gradient(circle, rgba(247, 244, 232, 0.88) 0 1px, transparent 1.35px),
      radial-gradient(circle, rgba(244, 255, 114, 0.7) 0 1px, transparent 1.35px),
      radial-gradient(circle, rgba(63, 142, 255, 0.52) 0 1px, transparent 1.4px);
    background-position: 0 0, 3.2rem 4.4rem, 7.1rem 1.6rem;
    background-size: 8rem 8rem, 12rem 12rem, 16rem 16rem;
    mask-image: linear-gradient(to bottom, transparent 0%, black 12%, black 82%, transparent 100%);
    opacity: 0.58;
  }

  .hero-pill {
    display: inline-flex;
    max-width: 100%;
    border: 1px solid rgba(244, 255, 114, 0.26);
    border-radius: 999px;
    background: rgba(244, 255, 114, 0.06);
    font-family: var(--font-mono);
    line-height: 1.35;
    text-wrap: pretty;
  }

  .hero-title {
    font-family: var(--font-display);
    text-wrap: balance;
    letter-spacing: -0.035em;
  }

  .hero-title span {
    color: var(--color-text-primary);
  }

  .hero-role {
    font-family: var(--font-mono);
    letter-spacing: 0.02em;
    text-transform: uppercase;
    text-shadow: 0 0 24px rgba(244, 255, 114, 0.22);
  }

  .hero-signals span {
    border: 1px solid rgba(255, 255, 255, 0.11);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.045);
    color: var(--color-text-secondary);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 700;
    padding: 0.38rem 0.62rem;
  }

  .hero-social-link {
    display: inline-flex;
    align-items: center;
    gap: 0.48rem;
    min-height: 2.45rem;
    border: 1px solid rgba(244, 255, 114, 0.16);
    border-radius: 999px;
    background: rgba(7, 8, 5, 0.46);
    color: var(--color-text-secondary);
    font-family: var(--font-mono);
    font-size: 0.76rem;
    font-weight: 800;
    padding: 0.56rem 0.74rem;
    transition: transform 0.2s ease, border-color 0.2s ease, color 0.2s ease, background-color 0.2s ease;
  }

  .hero-social-link:hover,
  .hero-social-link:focus-visible {
    transform: translateY(-2px);
    border-color: rgba(244, 255, 114, 0.52);
    background: rgba(244, 255, 114, 0.08);
    color: var(--color-text-primary);
  }

  .btn-cv {
    border: 1px solid rgba(244, 255, 114, 0.28);
    background: rgba(244, 255, 114, 0.08);
    color: var(--color-accent-cyan);
    box-shadow: inset 0 0 0 1px rgba(244, 255, 114, 0.04);
  }

  .btn-cv:hover,
  .btn-cv:focus-visible {
    border-color: rgba(244, 255, 114, 0.7);
    background: rgba(244, 255, 114, 0.14);
    transform: translateY(-1px);
  }

  .hero-contact-link {
    display: inline-flex;
    align-items: center;
    min-height: 2.75rem;
    color: var(--color-text-secondary);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 800;
    padding: 0.35rem 0.2rem;
    transition: color 0.2s ease, transform 0.2s ease;
  }

  .hero-contact-link:hover,
  .hero-contact-link:focus-visible {
    color: var(--color-accent-cyan);
    transform: translateX(0.15rem);
  }

  @media (prefers-reduced-motion: no-preference) {
    .hero-section::after {
      animation: mobile-star-drift 34s linear infinite;
    }

    @keyframes mobile-star-drift {
      from { background-position: 0 0, 3.2rem 4.4rem, 7.1rem 1.6rem; }
      to { background-position: 0 8rem, 3.2rem 16.4rem, 7.1rem 17.6rem; }
    }
  }

  @media (max-width: 767px) {
    .hero-section::after {
      display: block;
    }

    .credential-column {
      margin-top: 0.25rem;
    }
  }
</style>
