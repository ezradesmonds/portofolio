          {t(lang, "hero.github")}
        </a>
        <a
          href={SITE.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="hero-social-link"
          aria-label="LinkedIn profile"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          {t(lang, "hero.linkedin")}
        </a>
        <a
          href={SITE.instagram}
          target="_blank"
          rel="noopener noreferrer"
          class="hero-social-link"
          aria-label="Instagram profile"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          {t(lang, "hero.instagram")}
        </a>
      </div>
    </div>

    <div class="hidden md:flex justify-center z-10">
      <div
        class="execution-board w-full max-w-[26rem] lg:max-w-xl"
        aria-label="Ezra execution signal desk"
        data-signal-desk
        data-active-stage={initialStage.key}
      >
        <script type="application/json" data-signal-stages set:html={stagesJson}></script>
        <div class="board-topline">
          <span>{board.label}</span>
          <span data-board-state>{initialStage.state}</span>
        </div>

        <div class="simulation-bar">
          <div>
            <span>{board.meterTitle}</span>
            <strong data-stage-label aria-live="polite">{initialStage.label}</strong>
          </div>
          <div class="sim-actions">
            <button type="button" data-sim-run>{board.run}</button>
            <button type="button" data-sim-reset>{board.reset}</button>
          </div>
        </div>

        <div class="board-canvas">
          <article class="signal-card input-card" data-signal-card="input" role="button" tabindex="0">
            <span class="card-kicker">01 / INPUT</span>
            <h2>{board.input}</h2>
            <p>{board.inputBody}</p>
          </article>

          <div class="signal-router" aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
          </div>

          <article class="signal-card layer-card" data-signal-card="layer" role="button" tabindex="0">
            <span class="card-kicker">02 / LAYER</span>
            <h2>{board.layer}</h2>
            <p>{board.layerBody}</p>
          </article>

          <article class="signal-card output-card" data-signal-card="output" role="button" tabindex="0">
            <span class="card-kicker">03 / OUTPUT</span>
            <h2>{board.output}</h2>
            <p>{board.outputBody}</p>
          </article>

          <aside class="build-log">
            <span>{board.logTitle}</span>
            <ul>
              {board.logItems.map((item) => <li data-log-row>{item}</li>)}
            </ul>
          </aside>

          <aside class="signal-meter" aria-label={board.meterTitle}>
            <div>
              <span>{board.metricChaos}</span>
              <strong><span data-chaos-value>{initialStage.chaos}</span>%</strong>
            </div>
            <i><b data-chaos-bar style={`width: ${initialStage.chaos}%`}></b></i>
            <div>
              <span>{board.metricClarity}</span>
              <strong><span data-clarity-value>{initialStage.clarity}</span>%</strong>
            </div>
            <i><b data-clarity-bar style={`width: ${initialStage.clarity}%`}></b></i>
            <p data-next-action>{initialStage.action}</p>
          </aside>

          <div class="sticky-note">
            {board.note}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  function initSignalDesk() {
    const desks = document.querySelectorAll("[data-signal-desk]");
    if (!desks.length) return;

    const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    desks.forEach((desk) => {
      const config = desk.querySelector("[data-signal-stages]");
      const stages = JSON.parse(config?.textContent || "[]");
      const cards = Array.from(desk.querySelectorAll("[data-signal-card]"));
      const logs = Array.from(desk.querySelectorAll("[data-log-row]"));
      const runButton = desk.querySelector("[data-sim-run]");
      const resetButton = desk.querySelector("[data-sim-reset]");
      const stateEl = desk.querySelector("[data-board-state]");
      const stageLabel = desk.querySelector("[data-stage-label]");
      const chaosValue = desk.querySelector("[data-chaos-value]");
      const clarityValue = desk.querySelector("[data-clarity-value]");
      const chaosBar = desk.querySelector("[data-chaos-bar]");
      const clarityBar = desk.querySelector("[data-clarity-bar]");
      const nextAction = desk.querySelector("[data-next-action]");
      let timers = [];

      function clearTimers() {
        timers.forEach((timer) => window.clearTimeout(timer));
        timers = [];
      }

      function setStage(index) {
        const stage = stages[index] || stages[0];
        if (!stage) return;

        desk.setAttribute("data-active-stage", stage.key);
        desk.setAttribute("data-stage-index", String(index));
        if (stateEl) stateEl.textContent = stage.state;
        if (stageLabel) stageLabel.textContent = stage.label;
        if (chaosValue) chaosValue.textContent = stage.chaos;
        if (clarityValue) clarityValue.textContent = stage.clarity;
        if (chaosBar) chaosBar.style.width = `${stage.chaos}%`;
        if (clarityBar) clarityBar.style.width = `${stage.clarity}%`;
        if (nextAction) nextAction.textContent = stage.action;

        cards.forEach((card) => {
          card.classList.toggle("is-active", card.getAttribute("data-signal-card") === stage.key);
        });

        logs.forEach((log, logIndex) => {
          log.classList.toggle("is-done", logIndex <= index);
        });
      }

      function runSimulation() {
        clearTimers();
        if (prefersReduced) {
          setStage(stages.length - 1);
          return;
        }

        stages.forEach((_, index) => {
          timers.push(window.setTimeout(() => setStage(index), index * 720));
        });
      }

      cards.forEach((card) => {
        const activateCard = () => {
          clearTimers();
          const key = card.getAttribute("data-signal-card");
          const index = stages.findIndex((stage) => stage.key === key);
          setStage(index >= 0 ? index : 0);
        };

        card.addEventListener("click", activateCard);
        card.addEventListener("keydown", (event) => {
          if (event.key !== "Enter" && event.key !== " ") return;
          event.preventDefault();
          activateCard();
        });
      });

      runButton?.addEventListener("click", runSimulation);
      resetButton?.addEventListener("click", () => {
        clearTimers();
        setStage(0);
      });

      desk.addEventListener("pointermove", (event) => {
        const rect = desk.getBoundingClientRect();
        desk.style.setProperty("--spot-x", `${event.clientX - rect.left}px`);
        desk.style.setProperty("--spot-y", `${event.clientY - rect.top}px`);
      });

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            runSimulation();
            observer.disconnect();
          });
        },
        { threshold: 0.45 }
      );

      observer.observe(desk);
      setStage(0);
    });
  }

  document.addEventListener("DOMContentLoaded", initSignalDesk);
</script>

<style>
  .hero-section::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(circle at 13% 24%, rgba(244, 255, 114, 0.12), transparent 22rem),
      radial-gradient(circle at 84% 34%, rgba(63, 142, 255, 0.11), transparent 26rem);
    opacity: 0.9;
  }

  .hero-section::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 0;
    display: none;
    pointer-events: none;
    background-image:
      radial-gradient(circle, rgba(247, 244, 232, 0.88) 0 1px, transparent 1.35px),
      radial-gradient(circle, rgba(244, 255, 114, 0.7) 0 1px, transparent 1.35px),
      radial-gradient(circle, rgba(63, 142, 255, 0.52) 0 1px, transparent 1.4px);
    background-position:
      0 0,
      3.2rem 4.4rem,
      7.1rem 1.6rem;
    background-size:
      8rem 8rem,
      12rem 12rem,
      16rem 16rem;
    mask-image: linear-gradient(to bottom, transparent 0%, black 12%, black 82%, transparent 100%);
    opacity: 0.58;
  }

  .hero-pill {
    display: inline-flex;
    max-width: 100%;
    border: 1px solid rgba(244, 255, 114, 0.26);
    border-radius: 999px;
    background: rgba(244, 255, 114, 0.06);
    font-family: var(--font-mono);
    line-height: 1.35;
    text-wrap: pretty;
  }

  .hero-title {
    font-family: var(--font-display);
    text-wrap: balance;
    letter-spacing: -0.035em;
  }

  .hero-title span {
    color: var(--color-text-primary);
  }

  .hero-role {
    font-family: var(--font-mono);
    letter-spacing: 0.02em;
    text-transform: uppercase;
    text-shadow: 0 0 24px rgba(244, 255, 114, 0.22);
  }

  .hero-signals span {
    border: 1px solid rgba(255, 255, 255, 0.11);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.045);
    color: var(--color-text-secondary);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 700;
    padding: 0.38rem 0.62rem;
  }

  .hero-social-link {
    display: inline-flex;
    align-items: center;
    gap: 0.48rem;
    min-height: 2.45rem;
    border: 1px solid rgba(244, 255, 114, 0.16);
    border-radius: 999px;
    background: rgba(7, 8, 5, 0.46);
    color: var(--color-text-secondary);
    font-family: var(--font-mono);
    font-size: 0.76rem;
    font-weight: 800;
    padding: 0.56rem 0.74rem;
    transition: transform 0.2s ease, border-color 0.2s ease, color 0.2s ease, background-color 0.2s ease;
  }

  .hero-social-link:hover,
  .hero-social-link:focus-visible {
    transform: translateY(-2px);
    border-color: rgba(244, 255, 114, 0.52);
    background: rgba(244, 255, 114, 0.08);
    color: var(--color-text-primary);
  }

  .btn-cv {
    border: 1px solid rgba(244, 255, 114, 0.28);
    background: rgba(244, 255, 114, 0.08);
    color: var(--color-accent-cyan);
    box-shadow: inset 0 0 0 1px rgba(244, 255, 114, 0.04);
  }

  .btn-cv:hover,
  .btn-cv:focus-visible {
    border-color: rgba(244, 255, 114, 0.7);
    background: rgba(244, 255, 114, 0.14);
    transform: translateY(-1px);
  }

  .execution-board {
    --spot-x: 50%;
    --spot-y: 50%;
    position: relative;
    border: 1px solid rgba(244, 255, 114, 0.22);
    border-radius: 18px;
    background:
      linear-gradient(180deg, rgba(20, 23, 13, 0.94), rgba(8, 10, 6, 0.97)),
      radial-gradient(circle at 20% 10%, rgba(244, 255, 114, 0.18), transparent 20rem);
    box-shadow: 0 32px 70px rgba(0, 0, 0, 0.42);
    transform: rotate(-1deg);
    overflow: hidden;
    cursor: crosshair;
  }

  .execution-board::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(244, 255, 114, 0.055) 1px, transparent 1px),
      linear-gradient(90deg, rgba(244, 255, 114, 0.045) 1px, transparent 1px);
    background-size: 42px 42px;
    mask-image: linear-gradient(to bottom, black, transparent 88%);
    pointer-events: none;
  }

  .execution-board::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background: radial-gradient(circle at var(--spot-x) var(--spot-y), rgba(244, 255, 114, 0.2), transparent 12rem);
    opacity: 0.7;
    mix-blend-mode: screen;
  }

  .board-topline {
    position: relative;
    z-index: 1;
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    border-bottom: 1px solid rgba(244, 255, 114, 0.16);
    padding: 0.85rem 1rem;
    color: var(--color-accent-cyan);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .simulation-bar {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    border-bottom: 1px solid rgba(244, 255, 114, 0.12);
    padding: 0.7rem 1rem;
    background: rgba(244, 255, 114, 0.035);
    font-family: var(--font-mono);
  }

  .simulation-bar span {
    display: block;
    color: var(--color-text-muted);
    font-size: 0.58rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .simulation-bar strong {
    color: var(--color-text-primary);
    font-size: 0.72rem;
    line-height: 1;
  }

  .sim-actions {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
  }

  .sim-actions button {
    border: 1px solid rgba(244, 255, 114, 0.24);
    border-radius: 999px;
    background: rgba(244, 255, 114, 0.08);
    color: var(--color-accent-cyan);
    font-size: 0.58rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    line-height: 1;
    padding: 0.45rem 0.6rem;
    text-transform: uppercase;
    transition: transform 0.2s ease, background-color 0.2s ease, border-color 0.2s ease;
  }

  .sim-actions button:hover {
    transform: translateY(-1px);
    border-color: rgba(244, 255, 114, 0.7);
    background: rgba(244, 255, 114, 0.14);
  }

  .board-canvas {
    position: relative;
    z-index: 1;
    min-height: 28.5rem;
    padding: 1.2rem;
  }

  .signal-card,
  .build-log,
  .sticky-note {
    position: absolute;
    border-radius: 14px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(232, 226, 207, 0.94);
    color: #14160f;
    box-shadow: 0 20px 32px rgba(0, 0, 0, 0.24);
  }

  .signal-card {
    width: 15rem;
    padding: 1rem;
    cursor: pointer;
