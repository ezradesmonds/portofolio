---
import { resolveLang, t } from "../../i18n/utils";
import { SITE } from "../../data/site";

const lang = resolveLang(Astro.url.searchParams.get("lang"), Astro.cookies.get("lang")?.value);
---

<section id="contact" class="section">
  <div class="container-lg">
    <div class="max-w-3xl mx-auto text-center px-2 md:px-0">
      <span class="section-num">06.</span>
      <h2 class="text-2xl md:text-4xl lg:text-5xl font-bold text-white mt-3 mb-4 md:mb-6" set:html={t(lang, "contact.heading")}>
      </h2>
      <p class="text-base md:text-lg text-text-secondary mb-8 md:mb-10 max-w-xl mx-auto">
        {t(lang, "contact.subtitle")}
      </p>

      <form id="contact-form" class="max-w-md mx-auto text-left space-y-4 mb-8">
        <div>
          <label for="cf-name" class="block text-xs font-mono font-bold uppercase tracking-widest text-accent-cyan mb-1.5">
            {t(lang, "contact.form.name")}
          </label>
          <input
            type="text"
            id="cf-name"
            name="name"
            required
            placeholder={t(lang, "contact.form.namePlaceholder")}
            class="w-full px-4 py-2.5 bg-white/5 border border-white/10 rounded-lg text-white text-sm placeholder:text-text-muted focus:outline-none focus:border-accent-cyan/50 focus:ring-1 focus:ring-accent-cyan/20 transition-colors"
          />
        </div>
        <div>
          <label for="cf-email" class="block text-xs font-mono font-bold uppercase tracking-widest text-accent-cyan mb-1.5">
            {t(lang, "contact.form.email")}
          </label>
          <input
            type="email"
            id="cf-email"
            name="email"
            required
            placeholder={t(lang, "contact.form.emailPlaceholder")}
            class="w-full px-4 py-2.5 bg-white/5 border border-white/10 rounded-lg text-white text-sm placeholder:text-text-muted focus:outline-none focus:border-accent-cyan/50 focus:ring-1 focus:ring-accent-cyan/20 transition-colors"
          />
        </div>
        <div>
          <label for="cf-message" class="block text-xs font-mono font-bold uppercase tracking-widest text-accent-cyan mb-1.5">
            {t(lang, "contact.form.message")}
          </label>
          <textarea
            id="cf-message"
            name="message"
            required
            rows="4"
            placeholder={t(lang, "contact.form.messagePlaceholder")}
            class="w-full px-4 py-2.5 bg-white/5 border border-white/10 rounded-lg text-white text-sm placeholder:text-text-muted focus:outline-none focus:border-accent-cyan/50 focus:ring-1 focus:ring-accent-cyan/20 transition-colors resize-none"
          ></textarea>
        </div>
        <button
          type="submit"
          class="btn btn-primary w-full justify-center py-3 text-sm sm:text-base"
        >
          {t(lang, "contact.form.submit")}
        </button>
        <p id="cf-status" class="text-sm text-center hidden"></p>
      </form>

      <div class="flex items-center justify-center gap-3 text-sm text-text-muted">
        <span>{t(lang, "contact.form.or")}</span>
        <a href={`mailto:${SITE.email}`} class="text-accent-cyan hover:text-accent-violet transition-colors font-medium">
          {t(lang, "contact.sendEmail")}
        </a>
        <span class="text-text-muted">&middot;</span>
        <a href={SITE.linkedin} target="_blank" rel="noopener noreferrer" class="text-accent-cyan hover:text-accent-violet transition-colors font-medium">
          {t(lang, "contact.linkedin")}
        </a>
        <span class="text-text-muted">&middot;</span>
        <a href={SITE.github} target="_blank" rel="noopener noreferrer" class="text-accent-cyan hover:text-accent-violet transition-colors font-medium">
          {t(lang, "contact.github")}
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement | null;
  const status = document.getElementById("cf-status") as HTMLParagraphElement | null;
  if (!form || !status) throw new Error("Contact form elements not found");

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    const btn = form.querySelector("button") as HTMLButtonElement;

    const lang = (() => {
      const params = new URLSearchParams(location.search);
      const param = params.get("lang");
      if (param === "en" || param === "id") return param;
      const stored = localStorage.getItem("lang") || (document.cookie.match(/lang=([^;]+)/) || [])[1];
      return stored === "en" ? "en" : "id";
    })();

    const msgs: Record<string, Record<string, string>> = {
      en: { sending: "Sending...", success: "Message sent! I'll get back to you within 24 hours.", error: "Something went wrong. Please email me directly at ezradesmonds@gmail.com." },
      id: { sending: "Mengirim...", success: "Pesan terkirim! Saya akan membalas dalam 24 jam.", error: "Terjadi kesalahan. Silakan email saya langsung di ezradesmonds@gmail.com." },
    };
    const m = msgs[lang] || msgs.id;

    btn.disabled = true;
    btn.textContent = m.sending;
    status.classList.add("hidden");

    const data = new FormData(form);
    data.append("_captcha", "false");
    data.append("_template", "table");

    try {
      const res = await fetch("https://formsubmit.co/ezradesmonds@gmail.com", {
        method: "POST",
        body: data,
      });
      if (res.ok) {
        status.textContent = m.success;
        status.className = "text-sm text-center text-green-400";
        form.reset();
      } else {
        throw new Error("Form submission failed");
      }
    } catch {
      status.textContent = m.error;
      status.className = "text-sm text-center text-red-400";
    }

    status.classList.remove("hidden");
    btn.disabled = false;
    btn.textContent = lang === "en" ? "Send Message" : "Kirim Pesan";
  });
</script>
