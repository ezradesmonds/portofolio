---
import { resolveLang, t } from "../../i18n/utils";
import { experiences } from "../../data/experience";
import SectionHeading from "../ui/SectionHeading.astro";

const lang = resolveLang(Astro.url.searchParams.get("lang"), Astro.cookies.get("lang")?.value);
---

<section id="experience" class="section">
  <div class="container-lg">
    <SectionHeading
      number="03."
      title={t(lang, "experience.title")}
      subtitle={t(lang, "experience.subtitle")}
    />

    <div class="relative">
      <div class="absolute left-3 md:left-6 top-0 bottom-0 w-px bg-dark-border" aria-hidden="true"></div>

      <div class="space-y-10 md:space-y-12">
        {experiences.map((exp) => (
          <div class="relative pl-10 md:pl-16">
            <div class="absolute left-0 md:left-1.5 top-1.5 w-2.5 h-2.5 md:w-3 md:h-3 rounded-full bg-accent-cyan ring-4 ring-dark-base" aria-hidden="true"></div>

            <div class="flex flex-col md:flex-row md:items-baseline md:justify-between gap-2 mb-3">
              <h3 class="text-xl font-bold text-white">{exp.role}</h3>
              <span class="text-sm font-mono text-accent-cyan whitespace-nowrap">{exp.period}</span>
            </div>

            <p class="text-sm text-text-muted font-mono mb-1">{exp.organization}</p>
            <p class="text-text-secondary leading-relaxed mb-4">{exp.description}</p>

            <ul class="space-y-2">
              {exp.highlights.map((h) => (
                <li class="text-sm text-text-secondary flex items-start gap-2">
                  <span class="text-accent-cyan mt-1.5 flex-shrink-0" aria-hidden="true">&mdash;</span>
                  {h}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
