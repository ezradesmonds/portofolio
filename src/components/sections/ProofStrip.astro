---
import { resolveLang, t } from "../../i18n/utils";

const lang = resolveLang(Astro.url.searchParams.get("lang"), Astro.url.pathname);
---

<section class="border-b border-dark-border">
  <div class="max-w-7xl mx-auto px-4 md:px-6 py-8 md:py-12">
    <div class="signal-strip grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4">
      <div class="signal-proof">
        <div class="signal-value">2nd</div>
        <div class="signal-label" set:html={t(lang, "proof.hackathon")}></div>
      </div>
      <div class="signal-proof">
        <div class="signal-value">7+</div>
        <div class="signal-label" set:html={t(lang, "proof.products")}></div>
      </div>
      <div class="signal-proof">
        <div class="signal-value">3.75</div>
        <div class="signal-label" set:html={t(lang, "proof.gpa")}></div>
      </div>
      <div class="signal-proof">
        <div class="signal-value">NOW</div>
        <div class="signal-label" set:html={t(lang, "proof.local")}></div>
      </div>
    </div>
  </div>
</section>

<style>
  .signal-strip {
    position: relative;
  }

  .signal-proof {
    border: 1px solid rgba(244, 255, 114, 0.13);
    border-radius: 12px;
    background: rgba(16, 18, 11, 0.74);
    padding: 0.9rem;
  }

  .signal-value {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 4vw, 2.75rem);
    font-weight: 900;
    line-height: 0.9;
    color: var(--color-accent-cyan);
    letter-spacing: -0.04em;
  }

  .signal-label {
    margin-top: 0.55rem;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 700;
    line-height: 1.35;
  }
</style>
