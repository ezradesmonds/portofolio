---
import { resolveLang, t } from "../../i18n/utils";
import { projects, additionalProjects } from "../../data/projects";
import { localizeProjects } from "../../i18n/content";
import SectionHeading from "../ui/SectionHeading.astro";
import ProjectCard from "../ui/ProjectCard.astro";

const lang = resolveLang(Astro.url.searchParams.get("lang"), Astro.url.pathname);

const localizedProjects = localizeProjects(projects, lang);
const localizedAdditionalProjects = localizeProjects(additionalProjects, lang);
const featured = localizedProjects.filter((p) => p.featured).sort((a, b) => a.sortOrder - b.sortOrder);
const othersSorted = [...localizedProjects.filter((p) => !p.featured), ...localizedAdditionalProjects].sort((a, b) => a.sortOrder - b.sortOrder);
---

<section id="work" class="section">
  <div class="container-lg">
    <SectionHeading
      number="02."
      title={t(lang, "work.title")}
      subtitle={t(lang, "work.subtitle")}
    />

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6">
      {featured.map((project) => <ProjectCard project={project} lang={lang} />)}
    </div>

    {othersSorted.length > 0 && (
      <>
        <h3 class="text-xs sm:text-sm font-mono font-bold uppercase tracking-widest text-text-muted mt-14 sm:mt-20 mb-6 sm:mb-8">
          {t(lang, "work.moreProjects")}
        </h3>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6">
          {othersSorted.map((project) => <ProjectCard project={project} lang={lang} />)}
        </div>
      </>
    )}
  </div>
</section>
