---
import { localizedPath, t } from "../../i18n/utils";
import type { Lang, TranslationKey } from "../../i18n/translations";
import { SITE } from "../../data/site";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const homeHref = localizedPath(lang, "/");
const openLabel = t(lang, "nav.openMenu");
const closeLabel = t(lang, "nav.closeMenu");
const dialogLabel = lang === "id" ? "Navigasi mobile" : "Mobile navigation";

const navItems: { href: string; key: TranslationKey }[] = [
  { href: `${homeHref}#work`, key: "nav.work" },
  { href: localizedPath(lang, "/play/"), key: "nav.play" },
  { href: `${homeHref}#experience`, key: "nav.experience" },
  { href: `${homeHref}#about`, key: "nav.about" },
  { href: `${homeHref}#contact`, key: "nav.contact" },
];
---

<script>
  function initMobileMenu() {
    const btn = document.getElementById("mobile-menu-btn");
    const menu = document.getElementById("mobile-menu");
    if (!btn || !menu) return;

    const btnEl = btn as HTMLButtonElement;
    const menuEl = menu as HTMLDivElement;

    const srOnly = btnEl.querySelector(".sr-only") as HTMLSpanElement;
    const iconOpen = btnEl.querySelector(".icon-open") as SVGElement;
    const iconClose = btnEl.querySelector(".icon-close") as SVGElement;
    const openLabel = btnEl.dataset.openLabel ?? "Open menu";
    const closeLabel = btnEl.dataset.closeLabel ?? "Close menu";

    function open() {
      menuEl.classList.remove("hidden");
      document.body.style.overflow = "hidden";
      btnEl.setAttribute("aria-expanded", "true");
      btnEl.setAttribute("aria-label", closeLabel);
      if (srOnly) srOnly.textContent = closeLabel;
      iconOpen.classList.add("hidden");
      iconClose.classList.remove("hidden");
      (menuEl.querySelector("a") as HTMLAnchorElement)?.focus();
    }

    function close() {
      menuEl.classList.add("hidden");
      document.body.style.overflow = "";
      btnEl.setAttribute("aria-expanded", "false");
      btnEl.setAttribute("aria-label", openLabel);
      if (srOnly) srOnly.textContent = openLabel;
      iconOpen.classList.remove("hidden");
      iconClose.classList.add("hidden");
      btnEl.focus();
    }

    btnEl.addEventListener("click", () => {
      menuEl.classList.contains("hidden") ? open() : close();
    });

    menuEl.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", close);
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !menuEl.classList.contains("hidden")) close();
    });
  }

  document.addEventListener("DOMContentLoaded", initMobileMenu);
</script>

<button
  id="mobile-menu-btn"
  class="md:hidden relative z-[70] flex items-center justify-center w-10 h-10 text-white rounded-lg hover:bg-white/10 transition-colors"
  aria-expanded="false"
  aria-controls="mobile-menu"
  aria-label={openLabel}
  data-open-label={openLabel}
  data-close-label={closeLabel}
>
  <span class="sr-only">{openLabel}</span>
  <svg class="icon-open w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
  </svg>
  <svg class="icon-close w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
  </svg>
</button>

<div
  id="mobile-menu"
  class="hidden fixed inset-0 z-[60] h-dvh w-screen max-w-none bg-[#070805]/98 backdrop-blur-xl md:hidden"
  role="dialog"
  aria-modal="true"
  aria-label={dialogLabel}
>
  <nav class="mx-auto flex min-h-dvh w-full max-w-none flex-col items-center justify-center gap-6 px-6 py-24 text-center">
    {navItems.map((item) => (
      <a href={item.href} class="text-2xl font-semibold text-text-secondary hover:text-white transition-colors">{t(lang, item.key)}</a>
    ))}
    <a href={SITE.cvUrl} download class="text-2xl font-semibold text-text-secondary hover:text-white transition-colors">{t(lang, "nav.downloadCv")}</a>
    <a href={`mailto:${SITE.email}`} class="mt-4 px-6 py-3 text-base font-semibold border border-accent-cyan text-accent-cyan rounded-lg hover:bg-accent-cyan/10 transition-colors">{t(lang, "nav.getInTouch")}</a>
  </nav>
</div>

<style>
  #mobile-menu {
    position: fixed;
    inset: 0;
    width: 100vw;
    min-height: 100dvh;
    margin: 0;
    transform: none;
  }
</style>
