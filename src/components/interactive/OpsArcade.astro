---
import { translations, type Lang } from "../../i18n/translations";
import { SITE } from "../../data/site";
import { projects } from "../../data/projects";
import { capabilities } from "../../data/capabilities";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const existingCopy = translations[lang];
const selectedProjects = ["akun-ai", "tokokaret", "financeos"]
  .map((slug) => projects.find((project) => project.slug === slug))
  .filter((project): project is NonNullable<typeof project> => Boolean(project));
const skillLines = capabilities.slice(0, 3).map((group) =>
  group.items.slice(0, 3).map((item) => item.name).join(" / ")
);

const copy = {
  en: {
    eyebrow: "Interactive portfolio diagnostic",
    title: "Bug Hunt: Ezra's Desktop",
    intro: "Three windows are buried under interface corruption. Scrub them clean, expose each bug, and restore the system before it spreads.",
    instruction: "Mouse or touch: rub the dusty windows. Keyboard: focus a window and hold Space, then press Enter when the bug appears.",
    fixed: "Bugs fixed",
    status: "System status",
    contaminated: "Contaminated",
    clean: "System clean",
    relaxed: "Exploration mode",
    speed: "Speed run",
    best: "Personal best",
    noBest: "--",
    reset: "Reset desktop",
    startSpeed: "Start 45s speed run",
    retrySpeed: "Retry speed run",
    lockedSpeed: "Clear the desktop once to unlock speed run.",
    speedReady: "Speed run unlocked. Clear all three windows in 45 seconds.",
    speedFailed: "Time expired. The desktop is still infected.",
    speedComplete: "Speed run complete",
    scrub: "Scrub corruption",
    exposed: "Bug exposed — capture it",
    restored: "Window restored",
    capture: "Capture bug",
    completeTitle: "System clean.",
    completeBody: "You cleared the noise and uncovered the person behind the build. Explore the work or start a conversation.",
    workCta: "View selected work",
    contactCta: "Contact Ezra",
    zones: {
      profile: {
        label: "Profile terminal",
        title: "identity.exe",
        kicker: "Builder profile restored",
        heading: existingCopy["hero.role"],
        body: existingCopy["hero.subheadline"],
        education: `${existingCopy["about.education.detail"]} — ${existingCopy["about.education.school"]}`,
      },
      projects: {
        label: "Project workspace",
        title: "selected-work/",
        kicker: "Project index restored",
        heading: "Three systems, three different problems.",
      },
      connect: {
        label: "Connection panel",
        title: "open-channel.cfg",
        kicker: "Connection restored",
        heading: existingCopy["hero.availability"],
        body: existingCopy["contact.subtitle"],
      },
    },
  },
  id: {
    eyebrow: "Diagnostik portfolio interaktif",
    title: "Bug Hunt: Desktop Ezra",
    intro: "Tiga window tertutup korupsi interface. Gosok sampai bersih, temukan setiap bug, lalu pulihkan sistem sebelum menyebar.",
    instruction: "Mouse atau sentuh: gosok window berdebu. Keyboard: fokuskan window dan tahan Space, lalu tekan Enter saat bug muncul.",
    fixed: "Bug diperbaiki",
    status: "Status sistem",
    contaminated: "Terkontaminasi",
    clean: "Sistem bersih",
    relaxed: "Mode eksplorasi",
    speed: "Speed run",
    best: "Waktu terbaik",
    noBest: "--",
    reset: "Reset desktop",
    startSpeed: "Mulai speed run 45d",
    retrySpeed: "Ulangi speed run",
    lockedSpeed: "Bersihkan desktop sekali untuk membuka speed run.",
    speedReady: "Speed run terbuka. Bersihkan ketiga window dalam 45 detik.",
    speedFailed: "Waktu habis. Desktop masih terinfeksi.",
    speedComplete: "Speed run selesai",
    scrub: "Gosok korupsi",
    exposed: "Bug terlihat — tangkap sekarang",
    restored: "Window dipulihkan",
    capture: "Tangkap bug",
    completeTitle: "Sistem bersih.",
    completeBody: "Kamu sudah membersihkan noise dan menemukan builder di balik sistem ini. Lihat karya pilihan atau mulai percakapan.",
    workCta: "Lihat karya pilihan",
    contactCta: "Hubungi Ezra",
    zones: {
      profile: {
        label: "Terminal profil",
        title: "identitas.exe",
        kicker: "Profil builder dipulihkan",
        heading: existingCopy["hero.role"],
        body: existingCopy["hero.subheadline"],
        education: `${existingCopy["about.education.detail"]} — ${existingCopy["about.education.school"]}`,
      },
      projects: {
        label: "Workspace proyek",
        title: "karya-pilihan/",
        kicker: "Indeks proyek dipulihkan",
        heading: "Tiga sistem, tiga masalah berbeda.",
      },
      connect: {
        label: "Panel koneksi",
        title: "kanal-terbuka.cfg",
        kicker: "Koneksi dipulihkan",
        heading: existingCopy["hero.availability"],
        body: existingCopy["contact.subtitle"],
      },
    },
  },
}[lang];

const config = JSON.stringify({
  labels: {
    contaminated: copy.contaminated,
    clean: copy.clean,
    relaxed: copy.relaxed,
    speed: copy.speed,
    noBest: copy.noBest,
    startSpeed: copy.startSpeed,
    retrySpeed: copy.retrySpeed,
    lockedSpeed: copy.lockedSpeed,
    speedReady: copy.speedReady,
    speedFailed: copy.speedFailed,
    speedComplete: copy.speedComplete,
    scrub: copy.scrub,
    exposed: copy.exposed,
    restored: copy.restored,
  },
  storageKey: "ezra-bug-hunt-v1",
});

const workHref = lang === "id" ? "/id/#work" : "/#work";
const contactHref = lang === "id" ? "/id/#contact" : "/#contact";
---

<section class="hunt" data-bug-hunt>
  <script type="application/json" data-game-config set:html={config}></script>

  <div class="hunt__intro">
    <div>
      <p class="eyebrow">{copy.eyebrow}</p>
      <h1>{copy.title}</h1>
      <p class="lede">{copy.intro}</p>
      <p class="instruction">{copy.instruction}</p>
    </div>

    <aside class="hud" aria-label={copy.status}>
      <div class="hud__metric">
        <span>{copy.fixed}</span>
        <strong><b data-fixed>0</b>/3</strong>
      </div>
      <div class="hud__metric">
        <span>{copy.status}</span>
        <strong data-system-status>{copy.contaminated}</strong>
      </div>
      <div class="hud__metric hud__timer">
        <span data-mode-label>{copy.relaxed}</span>
        <strong data-timer>--</strong>
      </div>
      <div class="hud__metric">
        <span>{copy.best}</span>
        <strong data-best>{copy.noBest}</strong>
      </div>
      <div class="hud__actions">
        <button type="button" data-reset>{copy.reset}</button>
        <button type="button" data-speed disabled>{copy.startSpeed}</button>
      </div>
      <p data-hud-message>{copy.lockedSpeed}</p>
    </aside>
  </div>

  <div class="desktop" data-desktop>
    <div class="desktop__bar" aria-hidden="true">
      <span>EZRA_OS / LOCAL WORKSPACE</span>
      <span data-clock>20:26</span>
    </div>

    <div class="desktop__grid">
      <article class="window window--profile" data-zone="profile" tabindex="0" aria-label={`${copy.zones.profile.label}: ${copy.scrub}`}>
        <header class="window__bar">
          <span class="window__lights" aria-hidden="true"><i></i><i></i><i></i></span>
          <strong>{copy.zones.profile.title}</strong>
          <span data-zone-state>{copy.scrub}</span>
        </header>
        <div class="window__body terminal">
          <div class="reveal" data-reveal aria-hidden="true" inert>
            <p>{copy.zones.profile.kicker}</p>
            <h2>{copy.zones.profile.heading}</h2>
            <span>{copy.zones.profile.body}</span>
            <small class="education-line">{copy.zones.profile.education}</small>
            <ul>
              {skillLines.map((line) => <li>{line}</li>)}
            </ul>
          </div>
          <canvas data-dust aria-hidden="true"></canvas>
          <button class="bug" type="button" data-bug disabled aria-label={copy.capture}><span aria-hidden="true">✳</span><b>{copy.capture}</b></button>
          <div class="clean-progress" aria-hidden="true"><i data-progress></i></div>
        </div>
      </article>

      <article class="window window--projects" data-zone="projects" tabindex="0" aria-label={`${copy.zones.projects.label}: ${copy.scrub}`}>
        <header class="window__bar">
          <span class="window__lights" aria-hidden="true"><i></i><i></i><i></i></span>
          <strong>{copy.zones.projects.title}</strong>
          <span data-zone-state>{copy.scrub}</span>
        </header>
        <div class="window__body project-window">
          <div class="reveal" data-reveal aria-hidden="true" inert>
            <p>{copy.zones.projects.kicker}</p>
            <h2>{copy.zones.projects.heading}</h2>
            <div class="project-list">
              {selectedProjects.map((project) => (
                <a href={`${lang === "id" ? "/id" : ""}/work/${project.slug}/`} tabindex="-1">
                  <span>{project.statusLabel}</span>
                  <strong>{project.title}</strong>
                  <small>{project.role}</small>
                </a>
              ))}
            </div>
          </div>
          <canvas data-dust aria-hidden="true"></canvas>
          <button class="bug" type="button" data-bug disabled aria-label={copy.capture}><span aria-hidden="true">✳</span><b>{copy.capture}</b></button>
          <div class="clean-progress" aria-hidden="true"><i data-progress></i></div>
        </div>
      </article>

      <article class="window window--connect" data-zone="connect" tabindex="0" aria-label={`${copy.zones.connect.label}: ${copy.scrub}`}>
        <header class="window__bar">
          <span class="window__lights" aria-hidden="true"><i></i><i></i><i></i></span>
          <strong>{copy.zones.connect.title}</strong>
          <span data-zone-state>{copy.scrub}</span>
        </header>
        <div class="window__body connect-window">
          <div class="reveal" data-reveal aria-hidden="true" inert>
            <p>{copy.zones.connect.kicker}</p>
            <h2>{copy.zones.connect.heading}</h2>
            <span>{copy.zones.connect.body}</span>
            <div class="connection-links">
              <a href={`mailto:${SITE.email}`} tabindex="-1">Email</a>
              <a href={SITE.github} target="_blank" rel="noreferrer" tabindex="-1">GitHub</a>
              <a href={SITE.linkedin} target="_blank" rel="noreferrer" tabindex="-1">LinkedIn</a>
              <a href={SITE.cvUrl} target="_blank" rel="noreferrer" tabindex="-1">CV ↗</a>
            </div>
          </div>
          <canvas data-dust aria-hidden="true"></canvas>
          <button class="bug" type="button" data-bug disabled aria-label={copy.capture}><span aria-hidden="true">✳</span><b>{copy.capture}</b></button>
          <div class="clean-progress" aria-hidden="true"><i data-progress></i></div>
        </div>
      </article>
    </div>

    <div class="complete-panel" data-complete-panel aria-hidden="true">
      <p>03 / 03</p>
      <h2>{copy.completeTitle}</h2>
      <span>{copy.completeBody}</span>
      <div>
        <a href={workHref}>{copy.workCta}</a>
        <a href={contactHref}>{copy.contactCta}</a>
      </div>
    </div>
  </div>

  <p class="sr-only" aria-live="polite" data-live></p>
</section>

<script>
  type Labels = {
    contaminated: string; clean: string; relaxed: string; speed: string; noBest: string;
    startSpeed: string; retrySpeed: string; lockedSpeed: string; speedReady: string;
    speedFailed: string; speedComplete: string; scrub: string; exposed: string; restored: string;
  };
  type SavedGame = { completed?: boolean; best?: number };
  type ZoneState = {
    root: HTMLElement; canvas: HTMLCanvasElement; ctx: CanvasRenderingContext2D;
    cells: boolean[]; cleaned: number; exposed: boolean; captured: boolean; pointerId: number | null;
  };

  function initBugHunt() {
    const rootNode = document.querySelector<HTMLElement>("[data-bug-hunt]");
    if (!rootNode || rootNode.dataset.ready === "true") return;
    const root = rootNode;
    root.dataset.ready = "true";
    const configNode = root.querySelector<HTMLScriptElement>("[data-game-config]");
    if (!configNode?.textContent) return;
    const config = JSON.parse(configNode.textContent) as { labels: Labels; storageKey: string };
    const labels = config.labels;
    const columns = 12;
    const rows = 8;
    const threshold = 0.7;
    const duration = 45;
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const fixedNode = root.querySelector<HTMLElement>("[data-fixed]");
    const statusNode = root.querySelector<HTMLElement>("[data-system-status]");
    const timerNode = root.querySelector<HTMLElement>("[data-timer]");
    const modeNode = root.querySelector<HTMLElement>("[data-mode-label]");
    const bestNode = root.querySelector<HTMLElement>("[data-best]");
    const messageNode = root.querySelector<HTMLElement>("[data-hud-message]");
    const speedButton = root.querySelector<HTMLButtonElement>("[data-speed]");
    const completePanel = root.querySelector<HTMLElement>("[data-complete-panel]");
    const liveNode = root.querySelector<HTMLElement>("[data-live]");
    let saved: SavedGame = {};
    let mode: "relaxed" | "speed" = "relaxed";
    let speedActive = false;
    let deadline = 0;
    let hiddenAt = 0;
    let frame = 0;

    try { saved = JSON.parse(localStorage.getItem(config.storageKey) ?? "{}"); } catch { saved = {}; }

    const save = () => {
      try { localStorage.setItem(config.storageKey, JSON.stringify(saved)); } catch { /* storage is optional */ }
    };

    const seedFor = (id: string) => [...id].reduce((value, char) => value + char.charCodeAt(0), 17);
    const randomFor = (seed: number) => () => {
      seed = (seed * 1664525 + 1013904223) >>> 0;
      return seed / 4294967296;
    };

    const zones: ZoneState[] = Array.from(root.querySelectorAll<HTMLElement>("[data-zone]")).map((zoneRoot) => {
      const canvas = zoneRoot.querySelector<HTMLCanvasElement>("[data-dust]")!;
      const ctx = canvas.getContext("2d")!;
      return { root: zoneRoot, canvas, ctx, cells: Array(columns * rows).fill(false), cleaned: 0, exposed: false, captured: false, pointerId: null };
    });

    function formatTime(value: number) {
      return `${Math.max(0, value).toFixed(1)}s`;
    }

    function paintDust(zone: ZoneState) {
      const rect = zone.canvas.getBoundingClientRect();
      if (!rect.width || !rect.height) return;
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      zone.canvas.width = Math.round(rect.width * dpr);
      zone.canvas.height = Math.round(rect.height * dpr);
      zone.ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      const ctx = zone.ctx;
      const random = randomFor(seedFor(zone.root.dataset.zone ?? "zone"));
      ctx.clearRect(0, 0, rect.width, rect.height);
      ctx.fillStyle = "rgba(48, 39, 22, .88)";
      ctx.fillRect(0, 0, rect.width, rect.height);
      for (let index = 0; index < 150; index += 1) {
        const x = random() * rect.width;
        const y = random() * rect.height;
        const radius = 1 + random() * 8;
        ctx.beginPath();
        ctx.fillStyle = `rgba(${150 + random() * 65}, ${105 + random() * 45}, ${45 + random() * 25}, ${.12 + random() * .34})`;
        ctx.arc(x, y, radius, 0, Math.PI * 2);
        ctx.fill();
      }
      ctx.globalCompositeOperation = "destination-out";
      const cellWidth = rect.width / columns;
      const cellHeight = rect.height / rows;
      zone.cells.forEach((clean, index) => {
        if (!clean) return;
        const x = (index % columns + .5) * cellWidth;
        const y = (Math.floor(index / columns) + .5) * cellHeight;
        ctx.beginPath();
        ctx.arc(x, y, Math.max(cellWidth, cellHeight) * .86, 0, Math.PI * 2);
        ctx.fill();
      });
      ctx.globalCompositeOperation = "source-over";
    }

    function updateZone(zone: ZoneState) {
      const ratio = zone.cleaned / zone.cells.length;
      const progress = zone.root.querySelector<HTMLElement>("[data-progress]");
      if (progress) progress.style.width = `${Math.min(100, ratio * 100)}%`;
      if (ratio >= threshold && !zone.exposed) {
        zone.exposed = true;
        zone.root.classList.add("is-exposed");
        const bug = zone.root.querySelector<HTMLButtonElement>("[data-bug]");
        if (bug) bug.disabled = false;
        const state = zone.root.querySelector<HTMLElement>("[data-zone-state]");
        if (state) state.textContent = labels.exposed;
        zone.root.setAttribute("aria-label", labels.exposed);
        if (liveNode) liveNode.textContent = labels.exposed;
      }
    }

    function cleanAt(zone: ZoneState, clientX: number, clientY: number) {
      if (zone.captured || (mode === "speed" && !speedActive)) return;
      const rect = zone.canvas.getBoundingClientRect();
      if (clientX < rect.left || clientX > rect.right || clientY < rect.top || clientY > rect.bottom) return;
      const column = Math.floor(((clientX - rect.left) / rect.width) * columns);
      const row = Math.floor(((clientY - rect.top) / rect.height) * rows);
      for (let y = Math.max(0, row - 1); y <= Math.min(rows - 1, row + 1); y += 1) {
        for (let x = Math.max(0, column - 1); x <= Math.min(columns - 1, column + 1); x += 1) {
          const index = y * columns + x;
          if (!zone.cells[index]) { zone.cells[index] = true; zone.cleaned += 1; }
        }
      }
      paintDust(zone);
      updateZone(zone);
    }

    function keyboardClean(zone: ZoneState) {
      if (zone.captured || (mode === "speed" && !speedActive)) return;
      let added = 0;
      for (let index = 0; index < zone.cells.length && added < 7; index += 1) {
        if (!zone.cells[index]) { zone.cells[index] = true; zone.cleaned += 1; added += 1; }
      }
      paintDust(zone);
      updateZone(zone);
    }

    function capture(zone: ZoneState) {
      if (!zone.exposed || zone.captured || (mode === "speed" && !speedActive)) return;
      zone.captured = true;
      zone.root.classList.add("is-restored");
      zone.root.removeAttribute("tabindex");
      zone.canvas.style.pointerEvents = "none";
      const bug = zone.root.querySelector<HTMLButtonElement>("[data-bug]");
      if (bug) { bug.disabled = true; bug.setAttribute("aria-hidden", "true"); }
      const reveal = zone.root.querySelector<HTMLElement>("[data-reveal]");
      reveal?.setAttribute("aria-hidden", "false");
      reveal?.removeAttribute("inert");
      reveal?.querySelectorAll<HTMLElement>("a").forEach((link) => link.removeAttribute("tabindex"));
      const state = zone.root.querySelector<HTMLElement>("[data-zone-state]");
      if (state) state.textContent = labels.restored;
      zone.root.setAttribute("aria-label", labels.restored);
      if (navigator.vibrate) navigator.vibrate(35);
      if (liveNode) liveNode.textContent = labels.restored;
      updateHud();
    }

    function updateHud() {
      const fixed = zones.filter((zone) => zone.captured).length;
      if (fixedNode) fixedNode.textContent = String(fixed);
      if (fixed === zones.length) finishRun();
    }

    function finishRun() {
      speedActive = false;
      cancelAnimationFrame(frame);
      const wasSpeed = mode === "speed";
      if (wasSpeed) {
        const elapsed = Math.min(duration, duration - Math.max(0, (deadline - performance.now()) / 1000));
        if (!saved.best || elapsed < saved.best) saved.best = elapsed;
        if (messageNode) messageNode.textContent = `${labels.speedComplete}: ${formatTime(elapsed)}`;
      } else {
        saved.completed = true;
        if (messageNode) messageNode.textContent = labels.speedReady;
      }
      save();
      syncSavedState();
      if (statusNode) statusNode.textContent = labels.clean;
      root.classList.add("is-complete");
      completePanel?.setAttribute("aria-hidden", "false");
      if (liveNode) liveNode.textContent = labels.clean;
    }

    function syncSavedState() {
      if (speedButton) {
        speedButton.disabled = !saved.completed;
        speedButton.textContent = mode === "speed" ? labels.retrySpeed : labels.startSpeed;
      }
      if (bestNode) bestNode.textContent = saved.best ? formatTime(saved.best) : labels.noBest;
      if (saved.completed && mode === "relaxed" && messageNode) messageNode.textContent = labels.speedReady;
    }

    function resetZones() {
      root.classList.remove("is-complete");
      completePanel?.setAttribute("aria-hidden", "true");
      zones.forEach((zone) => {
        zone.cells.fill(false); zone.cleaned = 0; zone.exposed = false; zone.captured = false; zone.pointerId = null;
        zone.root.classList.remove("is-exposed", "is-restored");
        zone.root.setAttribute("tabindex", "0");
        zone.root.setAttribute("aria-label", labels.scrub);
        zone.canvas.style.pointerEvents = "auto";
        const reveal = zone.root.querySelector<HTMLElement>("[data-reveal]");
        reveal?.setAttribute("aria-hidden", "true");
        reveal?.setAttribute("inert", "");
        zone.root.querySelectorAll<HTMLElement>("[data-reveal] a").forEach((link) => link.setAttribute("tabindex", "-1"));
        const bug = zone.root.querySelector<HTMLButtonElement>("[data-bug]");
        if (bug) { bug.disabled = true; bug.removeAttribute("aria-hidden"); }
        const state = zone.root.querySelector<HTMLElement>("[data-zone-state]");
        if (state) state.textContent = labels.scrub;
        const progress = zone.root.querySelector<HTMLElement>("[data-progress]");
        if (progress) progress.style.width = "0%";
        paintDust(zone);
      });
      if (fixedNode) fixedNode.textContent = "0";
      if (statusNode) statusNode.textContent = labels.contaminated;
    }

    function resetRelaxed() {
      speedActive = false;
      cancelAnimationFrame(frame);
      mode = "relaxed";
      if (modeNode) modeNode.textContent = labels.relaxed;
      if (timerNode) timerNode.textContent = "--";
      if (messageNode) messageNode.textContent = saved.completed ? labels.speedReady : labels.lockedSpeed;
      resetZones();
      syncSavedState();
    }

    function timerLoop() {
      if (!speedActive) return;
      const remaining = Math.max(0, (deadline - performance.now()) / 1000);
      if (timerNode) timerNode.textContent = formatTime(remaining);
      if (remaining <= 0) {
        speedActive = false;
        if (messageNode) messageNode.textContent = labels.speedFailed;
        if (liveNode) liveNode.textContent = labels.speedFailed;
        if (speedButton) speedButton.textContent = labels.retrySpeed;
        return;
      }
      frame = requestAnimationFrame(timerLoop);
    }

    function startSpeedRun() {
      if (!saved.completed) return;
      mode = "speed";
      resetZones();
      speedActive = true;
      deadline = performance.now() + duration * 1000;
      if (modeNode) modeNode.textContent = labels.speed;
      if (messageNode) messageNode.textContent = labels.speedReady;
      if (speedButton) speedButton.textContent = labels.retrySpeed;
      timerLoop();
    }

    zones.forEach((zone) => {
      const surface = zone.canvas;
      surface.addEventListener("pointerdown", (event) => {
        if (zone.exposed) return;
        event.preventDefault();
        zone.pointerId = event.pointerId;
        surface.setPointerCapture(event.pointerId);
        cleanAt(zone, event.clientX, event.clientY);
      });
      surface.addEventListener("pointermove", (event) => {
        if (zone.pointerId !== event.pointerId || !(event.buttons || event.pointerType === "touch")) return;
        cleanAt(zone, event.clientX, event.clientY);
      });
      const endPointer = (event: PointerEvent) => {
        if (zone.pointerId === event.pointerId) zone.pointerId = null;
      };
      surface.addEventListener("pointerup", endPointer);
      surface.addEventListener("pointercancel", endPointer);
      zone.root.addEventListener("selectstart", (event) => {
        if (!zone.captured) event.preventDefault();
      });
      zone.root.addEventListener("dragstart", (event) => {
        if (!zone.captured) event.preventDefault();
      });
      zone.root.addEventListener("keydown", (event) => {
        if (event.key === " " && !zone.exposed) { event.preventDefault(); keyboardClean(zone); }
        if (event.key === "Enter" && zone.exposed) { event.preventDefault(); capture(zone); }
      });
      zone.root.querySelector("[data-bug]")?.addEventListener("click", () => capture(zone));
    });

    root.querySelector("[data-reset]")?.addEventListener("click", resetRelaxed);
    speedButton?.addEventListener("click", startSpeedRun);
    document.addEventListener("visibilitychange", () => {
      if (document.hidden && speedActive) hiddenAt = performance.now();
      if (!document.hidden && speedActive && hiddenAt) { deadline += performance.now() - hiddenAt; hiddenAt = 0; }
    });
    window.addEventListener("resize", () => zones.forEach(paintDust));
    root.querySelector<HTMLElement>("[data-clock]")!.textContent = new Intl.DateTimeFormat(undefined, { hour: "2-digit", minute: "2-digit" }).format(new Date());
    if (reduceMotion) root.classList.add("reduce-motion");
    resetRelaxed();
  }

  document.addEventListener("astro:page-load", initBugHunt);
  if (document.readyState !== "loading") initBugHunt();
  else document.addEventListener("DOMContentLoaded", initBugHunt, { once: true });
</script>

