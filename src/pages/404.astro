---
import BaseLayout from "../components/layout/BaseLayout.astro";
---

<BaseLayout title="Page Not Found — Ezra Desmond Sutanto">
  <section class="min-h-screen flex items-center justify-center px-6 pt-20">
    <div class="text-center max-w-lg">
      <span class="section-num">404</span>
      <h1 class="text-4xl md:text-6xl font-extrabold text-white mt-4 mb-6">
        Page Not Found
      </h1>
      <p class="text-text-secondary mb-10 leading-relaxed">
        The page you're looking for doesn't exist or has been moved.
        Let's get you back on track.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/" class="btn btn-primary">Back to Home</a>
        <a href="/#work" class="btn btn-secondary">View Work</a>
      </div>
    </div>
  </section>
</BaseLayout>
