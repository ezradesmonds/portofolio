---
import BaseLayout from "../../components/layout/BaseLayout.astro";
import OpsArcade from "../../components/interactive/OpsArcade.astro";

const structuredData = {
  "@context": "https://schema.org",
  "@type": "CreativeWork",
  name: "Bug Hunt: Desktop Ezra",
  description:
    "Game portfolio interaktif untuk membersihkan korupsi, menangkap bug, dan memulihkan desktop developer Ezra.",
  url: "https://ezradesmonds.my.id/id/play/",
  creator: {
    "@type": "Person",
    name: "Ezra Desmond Sutanto",
