---
import BaseLayout from "../../../components/layout/BaseLayout.astro";
import { projects, additionalProjects } from "../../../data/projects";
import { SITE } from "../../../data/site";
import TechBadge from "../../../components/ui/TechBadge.astro";
import { localizeProject } from "../../../i18n/content";

export function getStaticPaths() {
  const all = [...projects, ...additionalProjects];
  return all.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const all = [...projects, ...additionalProjects];
const rawProject = all.find((p) => p.slug === slug);

if (!rawProject) {
  return Astro.redirect("/404");
}

const lang = "id";
const project = localizeProject(rawProject, lang);
const detail = project.detail;
const label = {
  proof: "Bukti Visual",
  proofPending: "Artifact untuk project ini akan ditambahkan di batch 2.",
  aiSystem: "Catatan Sistem AI",
  provider: "Provider / Model",
  pipeline: "Pipeline",
  dataFlow: "Data Flow",
  validation: "Validasi",
  failureHandling: "Failure Handling",
  limitations: "Batasan Teknis",
  github: "Lihat di GitHub",
  githubProfile: "Profil GitHub",
};
const pageTitle = `${project.title} — ${SITE.name}`;
---

<BaseLayout title={pageTitle} description={project.description}>
  <article class="pt-32 pb-24 px-6">
    <div class="container-lg max-w-4xl">
      <a href="/id/#work" class="inline-flex items-center gap-2 text-sm text-text-muted hover:text-white transition-colors mb-8 font-mono">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        Kembali ke Karya
      </a>

      <div class="flex flex-wrap items-center gap-3 mb-4">
        <span class="text-xs font-mono text-accent-cyan">{project.category}</span>
        <span class={`text-[10px] font-mono font-semibold uppercase px-2 py-0.5 rounded border ${
          project.status === "live" ? "border-green-500/40 text-green-400 bg-green-500/10" :
          project.status === "in-development" ? "border-amber-500/40 text-amber-400 bg-amber-500/10" :
          project.status === "prototype" ? "border-sky-500/40 text-sky-400 bg-sky-500/10" :
          project.status === "competition" ? "border-violet-500/40 text-violet-400 bg-violet-500/10" :
          "border-slate-500/40 text-slate-400 bg-slate-500/10"
        }`}>
          {project.statusLabel}
        </span>
      </div>

      <h1 class="text-3xl md:text-5xl font-extrabold text-white mb-6">{project.title}</h1>
      <p class="text-xl text-text-secondary leading-relaxed mb-12">{project.description}</p>

      {project.screenshot && (
        <figure class="case-hero-shot mb-14">
          <img src={project.screenshot} alt={`${project.title} interface preview`} loading="eager" decoding="async" />
        </figure>
      )}

      {detail && (
        <div class="space-y-16">
          <section>
            <h2 class="text-sm font-mono font-bold uppercase tracking-widest text-accent-cyan mb-4">Ikhtisar</h2>
            <p class="text-text-secondary leading-relaxed">{detail.overview}</p>
          </section>

          <div class="grid md:grid-cols-2 gap-12">
            <div>
              <h2 class="text-sm font-mono font-bold uppercase tracking-widest text-accent-cyan mb-4">Masalah</h2>
              <p class="text-text-secondary">{project.problem}</p>
            </div>
            <div>
              <h2 class="text-sm font-mono font-bold uppercase tracking-widest text-accent-cyan mb-4">Target Pengguna</h2>
              <p class="text-text-secondary">{project.targetUsers}</p>
            </div>
          </div>

          <section>
            <h2 class="text-sm font-mono font-bold uppercase tracking-widest text-accent-cyan mb-4">Peran Saya</h2>
            <p class="text-base font-semibold text-white mb-2">{project.role}</p>
            <p class="text-text-secondary leading-relaxed">{project.contribution}</p>
          </section>

          <section>
            <h2 class="text-sm font-mono font-bold uppercase tracking-widest text-accent-cyan mb-4">Fitur Utama</h2>
            <ul class="grid sm:grid-cols-2 gap-3">
              {detail.keyFeatures.map((f) => (
                <li class="flex items-start gap-3 text-text-secondary text-sm">
                  <span class="text-accent-cyan mt-1 flex-shrink-0" aria-hidden="true">&rarr;</span>
                  {f}
                </li>
              ))}
            </ul>
          </section>

          {detail.aiSystem && (
            <section class="ai-system-panel">
              <h2 class="text-sm font-mono font-bold uppercase tracking-widest text-accent-cyan mb-5">{label.aiSystem}</h2>
              <div class="grid lg:grid-cols-[0.85fr_1.15fr] gap-6">
                <div class="space-y-4">
                  {detail.aiSystem.provider && (
                    <div class="ai-note">
                      <span>{label.provider}</span>
                      <p>{detail.aiSystem.provider}</p>
                    </div>
                  )}
                  {detail.aiSystem.dataFlow && (
                    <div class="ai-note">
                      <span>{label.dataFlow}</span>
                      <p>{detail.aiSystem.dataFlow}</p>
                    </div>
                  )}
                  {detail.aiSystem.validation && (
                    <div class="ai-note">
                      <span>{label.validation}</span>
                      <p>{detail.aiSystem.validation}</p>
                    </div>
                  )}
                  {detail.aiSystem.failureHandling && (
                    <div class="ai-note">
                      <span>{label.failureHandling}</span>
                      <p>{detail.aiSystem.failureHandling}</p>
                    </div>
                  )}
                  {detail.aiSystem.limitations && (
                    <div class="ai-note">
                      <span>{label.limitations}</span>
                      <p>{detail.aiSystem.limitations}</p>
                    </div>
                  )}
                </div>
                <div>
                  <h3 class="text-xs font-mono font-bold uppercase tracking-widest text-text-muted mb-3">{label.pipeline}</h3>
                  <ol class="ai-pipeline">
                    {detail.aiSystem.pipeline.map((item) => (
                      <li>{item}</li>
                    ))}
                  </ol>
                </div>
              </div>
            </section>
          )}

          {detail.challenges && detail.challenges.length > 0 && (
            <section>
              <h2 class="text-sm font-mono font-bold uppercase tracking-widest text-accent-cyan mb-4">Tantangan & Trade-off</h2>
              <ul class="space-y-3">
                {detail.challenges.map((c) => (
                  <li class="text-text-secondary text-sm pl-4 border-l-2 border-dark-border">{c}</li>
                ))}
              </ul>
            </section>
          )}

          {project.outcome && (
            <section>
              <h2 class="text-sm font-mono font-bold uppercase tracking-widest text-accent-cyan mb-4">Hasil</h2>
              <p class="text-text-secondary">{project.outcome}</p>
            </section>
          )}
        </div>
      )}

      {(project.proofArtifacts?.length || project.proofStatus === "pending") && (
        <section class="mt-16 pt-8 border-t border-dark-border">
          <h2 class="text-sm font-mono font-bold uppercase tracking-widest text-accent-cyan mb-5">{label.proof}</h2>
          {project.proofArtifacts?.length ? (
            <div class="proof-gallery">
              {project.proofArtifacts.map((artifact) => (
                <figure class="proof-artifact">
                  <img src={artifact.src} alt={artifact.alt} loading="lazy" decoding="async" />
                  <figcaption>{artifact.caption}</figcaption>
                </figure>
              ))}
            </div>
          ) : (
            <div class="proof-pending">
              <p>{label.proofPending}</p>
            </div>
          )}
        </section>
      )}

      <section class="mt-16 pt-8 border-t border-dark-border">
        <h2 class="text-sm font-mono font-bold uppercase tracking-widest text-accent-cyan mb-4">Teknologi</h2>
        <div class="flex flex-wrap gap-2">
          {project.technologies.map((t) => <TechBadge name={t} size="md" />)}
        </div>
      </section>

      <div class="flex flex-wrap gap-4 mt-12">
        {project.liveUrl && (
          <a href={project.liveUrl} target="_blank" rel="noopener noreferrer" class="btn btn-primary">
            Kunjungi Situs Live
          </a>
        )}
        {project.githubUrl && (
          <a href={project.githubUrl} target="_blank" rel="noopener noreferrer" class="btn btn-secondary">
            {project.githubLabel ?? (project.githubIsGeneric ? label.githubProfile : label.github)}
          </a>
        )}
      </div>

      <nav class="mt-16 pt-8 border-t border-dark-border flex justify-between">
        <a href="/id/#work" class="text-sm text-text-muted hover:text-white transition-colors font-mono">
          &larr; Semua Proyek
        </a>
        <a href="/id/#contact" class="text-sm text-accent-cyan hover:underline font-mono">
          Hubungi Saya &rarr;
        </a>
      </nav>
    </div>
  </article>
</BaseLayout>

<style>
  .case-hero-shot {
    overflow: hidden;
    border: 1px solid rgba(244, 255, 114, 0.16);
    border-radius: 1rem;
    background: rgba(0, 0, 0, 0.28);
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.28);
  }

  .case-hero-shot img {
    width: 100%;
    max-height: 34rem;
    object-fit: cover;
    display: block;
  }

  .ai-system-panel {
    border: 1px solid rgba(244, 255, 114, 0.14);
    border-radius: 1rem;
    background: linear-gradient(145deg, rgba(23, 26, 16, 0.86), rgba(9, 10, 7, 0.92));
    padding: clamp(1rem, 2vw, 1.5rem);
  }

  .ai-note {
    border-left: 2px solid rgba(244, 255, 114, 0.32);
    padding-left: 0.9rem;
  }

  .ai-note span {
    display: block;
    color: var(--color-accent-cyan);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    margin-bottom: 0.35rem;
    text-transform: uppercase;
  }

  .ai-note p,
  .ai-pipeline li {
    color: var(--color-text-secondary);
    font-size: 0.9rem;
    line-height: 1.65;
  }

  .ai-pipeline {
    display: grid;
    gap: 0.75rem;
    counter-reset: pipeline;
  }

  .ai-pipeline li {
    position: relative;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 0.75rem;
    background: rgba(255, 255, 255, 0.035);
    padding: 0.85rem 0.95rem 0.85rem 2.8rem;
  }

  .ai-pipeline li::before {
    counter-increment: pipeline;
    content: counter(pipeline, decimal-leading-zero);
    position: absolute;
    left: 0.85rem;
    top: 0.95rem;
    color: var(--color-accent-cyan);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 900;
  }

  .proof-gallery {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 18rem), 1fr));
    gap: 1rem;
  }

  .proof-artifact {
    overflow: hidden;
    border: 1px solid rgba(244, 255, 114, 0.14);
    border-radius: 0.9rem;
    background: rgba(16, 18, 11, 0.72);
  }

  .proof-artifact img {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    display: block;
    border-bottom: 1px solid rgba(244, 255, 114, 0.12);
  }

  .proof-artifact figcaption,
  .proof-pending p {
    color: var(--color-text-secondary);
    font-size: 0.82rem;
    line-height: 1.55;
    padding: 0.85rem;
  }

  .proof-pending {
    border: 1px dashed rgba(244, 255, 114, 0.18);
    border-radius: 0.9rem;
    background: rgba(255, 255, 255, 0.035);
  }
</style>
