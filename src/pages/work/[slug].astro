---
import BaseLayout from "../../components/layout/BaseLayout.astro";
import { projects, additionalProjects } from "../../data/projects";
import { SITE } from "../../data/site";
import TechBadge from "../../components/ui/TechBadge.astro";
import EvidenceMetrics from "../../components/projects/EvidenceMetrics.astro";
import FeatureStatusTable from "../../components/projects/FeatureStatusTable.astro";
import { localizeProject } from "../../i18n/content";
import { localizedPath, resolveLang } from "../../i18n/utils";

export function getStaticPaths() {
  const all = [...projects, ...additionalProjects];
  return all.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const all = [...projects, ...additionalProjects];
const rawProject = all.find((p) => p.slug === slug);

if (!rawProject) {
  return Astro.redirect("/404");
}

const lang = resolveLang(Astro.url.searchParams.get("lang"), Astro.url.pathname);
const project = localizeProject(rawProject, lang);
const detail = project.detail;
const pageTitle = project.seoTitle ?? `${project.title} Case Study - ${SITE.name}`;
const pageDescription = project.seoDescription ?? project.description;
const projectImage = project.screenshot ? new URL(project.screenshot, SITE.url).toString() : undefined;
const projectStructuredData = {
  "@context": "https://schema.org",
  "@type": project.githubUrl || project.githubLinks?.length ? "SoftwareSourceCode" : "CreativeWork",
  name: project.title,
  description: pageDescription,
  url: new URL(Astro.url.pathname, SITE.url).toString(),
  image: projectImage,
  creator: {
    "@type": "Person",
    name: SITE.name,
    url: SITE.url,
  },
  applicationCategory: project.category,
  programmingLanguage: project.technologies,
  codeRepository: project.githubUrl ?? project.githubLinks?.[0]?.url,
};
const backHref = `${localizedPath(lang, "/")}#work`;
const contactHref = `${localizedPath(lang, "/")}#contact`;
const label = {
  back: lang === "id" ? "Kembali ke Karya" : "Back to Work",
  overview: lang === "id" ? "Ikhtisar" : "Overview",
  problem: lang === "id" ? "Masalah" : "Problem",
  users: lang === "id" ? "Target Pengguna" : "Target Users",
  role: lang === "id" ? "Peran Saya" : "My Role",
  contribution: lang === "id" ? "Kontribusi spesifik saya" : "My exact contribution",
  evidence: lang === "id" ? "Metrik terverifikasi" : "Verified evidence",
  featureStatus: lang === "id" ? "Status fitur" : "Feature status",
  features: lang === "id" ? "Fitur Utama" : "Key Features",
  challenges: lang === "id" ? "Tantangan & Trade-off" : "Challenges & Trade-offs",
  lessons: lang === "id" ? "Pelajaran" : "Lessons Learned",
  results: lang === "id" ? "Hasil" : "Results",
  technologies: lang === "id" ? "Teknologi" : "Technologies",
  visit: lang === "id" ? "Kunjungi Situs Live" : "Visit Live Site",
  github: lang === "id" ? "Lihat di GitHub" : "View on GitHub",
  githubProfile: lang === "id" ? "Profil GitHub" : "GitHub Profile",
  proof: lang === "id" ? "Bukti Visual" : "Proof Artifacts",
  proofPending: lang === "id"
    ? "Artifact untuk project ini akan ditambahkan di batch 2."
    : "Artifacts for this project will be added in batch 2.",
  aiSystem: lang === "id" ? "Catatan Sistem AI" : "AI System Notes",
  provider: lang === "id" ? "Provider / Model" : "Provider / Model",
  pipeline: lang === "id" ? "Pipeline" : "Pipeline",
  dataFlow: lang === "id" ? "Data Flow" : "Data Flow",
  validation: lang === "id" ? "Validasi" : "Validation",
  failureHandling: lang === "id" ? "Failure Handling" : "Failure Handling",
  limitations: lang === "id" ? "Batasan Teknis" : "Technical Limitations",
  all: lang === "id" ? "Semua Proyek" : "All Projects",
  contact: lang === "id" ? "Hubungi Saya" : "Get in Touch",
};
const featureStatusLabels = lang === "id"
  ? { working: "Berfungsi", prototype: "Prototype", planned: "Direncanakan", unvalidated: "Belum tervalidasi" }
  : { working: "Working", prototype: "Prototype", planned: "Planned", unvalidated: "Unvalidated" };

const githubLinks = project.githubLinks?.length
  ? project.githubLinks
  : project.githubUrl
    ? [
        {
          url: project.githubUrl,
          label: project.githubLabel ?? (project.githubIsGeneric ? label.githubProfile : label.github),
          isGeneric: project.githubIsGeneric,
        },
      ]
    : [];
---

<BaseLayout title={pageTitle} description={pageDescription} image={project.screenshot} structuredData={projectStructuredData}>
  <article class="pt-32 pb-24 px-6">
    <div class="container-lg max-w-4xl">
      <a href={backHref} class="inline-flex items-center gap-2 text-sm text-text-muted hover:text-white transition-colors mb-8 font-mono">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        {label.back}
      </a>

      <div class="flex flex-wrap items-center gap-3 mb-4">
        <span class="text-xs font-mono text-accent-cyan">{project.category}</span>
        <span class={`text-[10px] font-mono font-semibold uppercase px-2 py-0.5 rounded border ${
          project.status === "live" ? "border-green-500/40 text-green-400 bg-green-500/10" :
          project.status === "in-development" ? "border-amber-500/40 text-amber-400 bg-amber-500/10" :
          project.status === "prototype" ? "border-sky-500/40 text-sky-400 bg-sky-500/10" :
          project.status === "competition" ? "border-violet-500/40 text-violet-400 bg-violet-500/10" :
          "border-slate-500/40 text-slate-400 bg-slate-500/10"
        }`}>
          {project.statusLabel}
        </span>
      </div>

      <h1 class="text-3xl md:text-5xl font-extrabold text-white mb-6">{project.title}</h1>
      <p class="text-xl text-text-secondary leading-relaxed mb-12">{project.description}</p>

      {project.screenshot && (
        <figure class="case-hero-shot mb-14">
          <img src={project.screenshot} alt={`${project.title} interface preview`} loading="eager" decoding="async" />
        </figure>
      )}

      {detail && (
        <div class="space-y-16">
          <section>
            <h2 class="text-sm font-mono font-bold uppercase tracking-widest text-accent-cyan mb-4">{label.overview}</h2>
            <p class="text-text-secondary leading-relaxed">{detail.overview}</p>
          </section>

          {detail.metrics && detail.metrics.length > 0 && (
            <EvidenceMetrics metrics={detail.metrics} title={label.evidence} />
          )}

          <div class="grid md:grid-cols-2 gap-12">
            <div>
              <h2 class="text-sm font-mono font-bold uppercase tracking-widest text-accent-cyan mb-4">{label.problem}</h2>
              <p class="text-text-secondary">{project.problem}</p>
            </div>
            <div>
              <h2 class="text-sm font-mono font-bold uppercase tracking-widest text-accent-cyan mb-4">{label.users}</h2>
              <p class="text-text-secondary">{project.targetUsers}</p>
            </div>
          </div>

          <section>
            <h2 class="text-sm font-mono font-bold uppercase tracking-widest text-accent-cyan mb-4">{label.role}</h2>
            <p class="text-base font-semibold text-white mb-2">{project.role}</p>
            <p class="text-text-secondary leading-relaxed">{project.contribution}</p>
          </section>

          {detail.mySpecificBuilds && detail.mySpecificBuilds.length > 0 && (
            <section class="contribution-panel">
              <h2 class="text-sm font-mono font-bold uppercase tracking-widest text-accent-cyan mb-4">{label.contribution}</h2>
              <ul class="contribution-list">
                {detail.mySpecificBuilds.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </section>
          )}

          <section>
            <h2 class="text-sm font-mono font-bold uppercase tracking-widest text-accent-cyan mb-4">{label.features}</h2>
            <ul class="grid sm:grid-cols-2 gap-3">
              {detail.keyFeatures.map((f) => (
                <li class="flex items-start gap-3 text-text-secondary text-sm">
                  <span class="text-accent-cyan mt-1 flex-shrink-0" aria-hidden="true">&rarr;</span>
                  {f}
                </li>
              ))}
            </ul>
          </section>

          {detail.featureStatus && detail.featureStatus.length > 0 && (
            <FeatureStatusTable items={detail.featureStatus} title={label.featureStatus} statusLabels={featureStatusLabels} />
          )}

          {detail.aiSystem && (
            <section class="ai-system-panel">
              <h2 class="text-sm font-mono font-bold uppercase tracking-widest text-accent-cyan mb-5">{label.aiSystem}</h2>
              <div class="grid lg:grid-cols-[0.85fr_1.15fr] gap-6">
                <div class="space-y-4">
                  {detail.aiSystem.provider && (
                    <div class="ai-note">
                      <span>{label.provider}</span>
                      <p>{detail.aiSystem.provider}</p>
                    </div>
                  )}
                  {detail.aiSystem.dataFlow && (
                    <div class="ai-note">
                      <span>{label.dataFlow}</span>
                      <p>{detail.aiSystem.dataFlow}</p>
                    </div>
                  )}
                  {detail.aiSystem.validation && (
                    <div class="ai-note">
                      <span>{label.validation}</span>
                      <p>{detail.aiSystem.validation}</p>
                    </div>
                  )}
                  {detail.aiSystem.failureHandling && (
                    <div class="ai-note">
                      <span>{label.failureHandling}</span>
                      <p>{detail.aiSystem.failureHandling}</p>
                    </div>
                  )}
                  {detail.aiSystem.limitations && (
                    <div class="ai-note">
                      <span>{label.limitations}</span>
                      <p>{detail.aiSystem.limitations}</p>
                    </div>
                  )}
                </div>
                <div>
                  <h3 class="text-xs font-mono font-bold uppercase tracking-widest text-text-muted mb-3">{label.pipeline}</h3>
                  <ol class="ai-pipeline">
                    {detail.aiSystem.pipeline.map((item) => (
                      <li>{item}</li>
                    ))}
                  </ol>
                </div>
              </div>
            </section>
          )}

          {detail.challenges && detail.challenges.length > 0 && (
            <section>
              <h2 class="text-sm font-mono font-bold uppercase tracking-widest text-accent-cyan mb-4">{label.challenges}</h2>
              <ul class="space-y-3">
                {detail.challenges.map((c) => (
                  <li class="text-text-secondary text-sm pl-4 border-l-2 border-dark-border">{c}</li>
                ))}
              </ul>
            </section>
          )}

          {detail.lessonsLearned && detail.lessonsLearned.length > 0 && (
            <section>
              <h2 class="text-sm font-mono font-bold uppercase tracking-widest text-accent-cyan mb-4">{label.lessons}</h2>
              <ul class="space-y-3">
                {detail.lessonsLearned.map((l) => (
                  <li class="text-text-secondary text-sm pl-4 border-l-2 border-accent-violet/30">{l}</li>
                ))}
              </ul>
            </section>
          )}

          {project.outcome && (
            <section>
              <h2 class="text-sm font-mono font-bold uppercase tracking-widest text-accent-cyan mb-4">{label.results}</h2>
              <p class="text-text-secondary">{project.outcome}</p>
            </section>
          )}
        </div>
      )}

      {(project.proofArtifacts?.length || project.proofStatus === "pending") && (
        <section class="mt-16 pt-8 border-t border-dark-border">
          <h2 class="text-sm font-mono font-bold uppercase tracking-widest text-accent-cyan mb-5">{label.proof}</h2>
          {project.proofArtifacts?.length ? (
            <div class:list={["proof-gallery", { "proof-gallery--mobile": project.slug === "servisin" }]}>
              {project.proofArtifacts.map((artifact) => (
                <figure class="proof-artifact">
                  {artifact.kind === "video" ? (
                    <video src={artifact.src} poster={artifact.poster} controls preload="metadata" aria-label={artifact.alt}></video>
                  ) : (
                    <img src={artifact.src} alt={artifact.alt} loading="lazy" decoding="async" />
                  )}
                  <figcaption>{artifact.caption}</figcaption>
                </figure>
              ))}
            </div>
          ) : (
            <div class="proof-pending">
              <p>{label.proofPending}</p>
            </div>
          )}
        </section>
      )}

      <section class="mt-16 pt-8 border-t border-dark-border">
        <h2 class="text-sm font-mono font-bold uppercase tracking-widest text-accent-cyan mb-4">{label.technologies}</h2>
        <div class="flex flex-wrap gap-2">
          {project.technologies.map((t) => <TechBadge name={t} size="md" />)}
        </div>
      </section>

      <div class="flex flex-wrap gap-4 mt-12">
        {project.liveUrl && (
          <a href={project.liveUrl} target="_blank" rel="noopener noreferrer" class="btn btn-primary">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
            {label.visit}
          </a>
        )}
        {githubLinks.map((link) => (
          <a href={link.url} target="_blank" rel="noopener noreferrer" class="btn btn-secondary">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/></svg>
            {link.label ?? (link.isGeneric ? label.githubProfile : label.github)}
          </a>
        ))}
      </div>

      <nav class="mt-16 pt-8 border-t border-dark-border flex justify-between">
        <a href={backHref} class="text-sm text-text-muted hover:text-white transition-colors font-mono">
          &larr; {label.all}
        </a>
        <a href={contactHref} class="text-sm text-accent-cyan hover:underline font-mono">
          {label.contact} &rarr;
        </a>
      </nav>
    </div>
  </article>
</BaseLayout>

<style>
  .case-hero-shot {
    overflow: hidden;
    border: 1px solid rgba(244, 255, 114, 0.16);
    border-radius: 1rem;
    background: rgba(0, 0, 0, 0.28);
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.28);
  }

  .case-hero-shot img {
    width: 100%;
    max-height: 34rem;
    object-fit: cover;
    display: block;
  }

  .ai-system-panel {
    border: 1px solid rgba(244, 255, 114, 0.14);
    border-radius: 1rem;
    background: linear-gradient(145deg, rgba(23, 26, 16, 0.86), rgba(9, 10, 7, 0.92));
    padding: clamp(1rem, 2vw, 1.5rem);
  }

  .contribution-panel {
    border: 1px solid rgba(244, 255, 114, 0.14);
    border-radius: 1rem;
    background: rgba(16, 18, 11, 0.64);
    padding: clamp(1rem, 2vw, 1.5rem);
  }

  .contribution-list {
    display: grid;
    gap: 0.75rem;
  }

  .contribution-list li {
    position: relative;
    color: var(--color-text-secondary);
    font-size: 0.93rem;
    line-height: 1.65;
    padding-left: 1.35rem;
  }

  .contribution-list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.68rem;
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 999px;
    background: var(--color-accent-cyan);
    box-shadow: 0 0 12px rgba(244, 255, 114, 0.28);
  }

  .ai-note {
    border-left: 2px solid rgba(244, 255, 114, 0.32);
    padding-left: 0.9rem;
  }

  .ai-note span {
    display: block;
    color: var(--color-accent-cyan);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    margin-bottom: 0.35rem;
    text-transform: uppercase;
  }

  .ai-note p,
  .ai-pipeline li {
    color: var(--color-text-secondary);
    font-size: 0.9rem;
    line-height: 1.65;
  }

  .ai-pipeline {
    display: grid;
    gap: 0.75rem;
    counter-reset: pipeline;
  }

  .ai-pipeline li {
    position: relative;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 0.75rem;
    background: rgba(255, 255, 255, 0.035);
    padding: 0.85rem 0.95rem 0.85rem 2.8rem;
  }

  .ai-pipeline li::before {
    counter-increment: pipeline;
    content: counter(pipeline, decimal-leading-zero);
    position: absolute;
    left: 0.85rem;
    top: 0.95rem;
    color: var(--color-accent-cyan);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 900;
  }

  .proof-gallery {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 18rem), 1fr));
    gap: 1rem;
  }

  .proof-artifact {
    overflow: hidden;
    border: 1px solid rgba(244, 255, 114, 0.14);
    border-radius: 0.9rem;
    background: rgba(16, 18, 11, 0.72);
  }

  .proof-artifact img,
  .proof-artifact video {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    object-position: top center;
    display: block;
    border-bottom: 1px solid rgba(244, 255, 114, 0.12);
    background: #050604;
  }

  .proof-gallery--mobile .proof-artifact img,
  .proof-gallery--mobile .proof-artifact video {
    aspect-ratio: 9 / 19.5;
    object-fit: contain;
  }

  .proof-artifact figcaption,
  .proof-pending p {
    color: var(--color-text-secondary);
    font-size: 0.82rem;
    line-height: 1.55;
    padding: 0.85rem;
  }

  .proof-pending {
    border: 1px dashed rgba(244, 255, 114, 0.18);
    border-radius: 0.9rem;
    background: rgba(255, 255, 255, 0.035);
  }
</style>
